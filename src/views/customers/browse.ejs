<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Browse Cooks</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

<div class="main-box">
<main class="main-content">
    <!-- ── Hero Search ────────────────────────────── -->
    <div class="browse-hero">
        <h2>What are you craving today?</h2>
        <p>Discover homemade meals from talented cooks right in your neighborhood.</p>
        <form action="/customer/browse" method="get">
            <div class="browse-search-bar">
                <i class="bi bi-search" style="color:#aaa;font-size:18px;flex-shrink:0;"></i>
                <input type="text" name="q" placeholder="Search for dishes, cuisines, or cooks…" value="<%= q || '' %>">
                <button type="submit" class="search-btn">Search</button>
            </div>
        </form>
    </div>

    <!-- All Cooks Near You -->
    <div>
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <h3 class="browse-section-title mb-0"><i class="bi bi-geo-alt me-1"></i><%= q ? 'Results for "' + q + '"' : 'All Cooks Near You' %></h3>
            <div class="d-flex align-items-center gap-2">
                <span style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;"><%= merchants.length %> cooks found</span>
                <select id="sort-select" class="form-select form-select-sm" style="max-width:170px;font-family:'Poppins',sans-serif;font-size:0.82rem;">
                    <option value="popularity">Sort: Popularity</option>
                    <option value="rating">Sort: Rating</option>
                    <option value="price-asc">Sort: Price ↑</option>
                    <option value="price-desc">Sort: Price ↓</option>
                </select>
            </div>
        </div>

        <div class="row g-3 mx-1" id="merchant-grid">

            <% if (merchants.length === 0) { %>
            <div class="col-12 text-center py-5" style="color:#888;font-family:'Open Sans',sans-serif;">
                <i class="bi bi-search" style="font-size:2rem;"></i>
                <p class="mt-2">No cooks found for "<%= q %>".<br>Try a different search term.</p>
            </div>
            <% } %>
            <% merchants.forEach(merchant => { %>
            <div class="col-6 col-md-4 col-lg-3 merchant-col"
                 data-order-count="<%= merchant.OrderCount || 0 %>"
                 data-rating="<%= merchant.StoreScore || 0 %>"
                 data-price="<%= merchant.AvgPrice || 0 %>">
                <a href="/customer/merchant/<%= merchant.MerchantID %>" class="restaurant-card">
                    <div class="restaurant-card-img" style="background:#f5ede0;<% if (merchant.StoreImage) { %>background-image:url('<%= merchant.StoreImage %>');background-size:cover;background-position:center;<% } %>"></div>
                    <div class="restaurant-card-body">
                        <div class="restaurant-card-name"><%= merchant.MerchantName %></div>
                        <div class="restaurant-card-meta">⭐ <%= merchant.StoreScore%>, Avg $<%= merchant.AvgPrice %></div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div><!-- /row -->

        <div class="text-center mt-4">
            <button class="btn btn-hp-outline px-5">
                <i class="bi bi-chevron-down me-1"></i>Load More
            </button>
        </div>
    </div><!-- /all cooks -->

</div><!-- /browse-page -->
</div><!-- /content-below-hero -->
</main>
</div><!-- /main-box -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/common-elements.js"></script>
<script>
    const sortSelect = document.getElementById('sort-select');
    const merchantGrid = document.getElementById('merchant-grid');

    if (sortSelect && merchantGrid) {
        sortSelect.addEventListener('change', function () {
            const cols = Array.from(merchantGrid.querySelectorAll('.merchant-col'));
            const val = this.value;

            cols.sort((a, b) => {
                if (val === 'popularity') {
                    return parseFloat(b.dataset.orderCount) - parseFloat(a.dataset.orderCount);
                }
                if (val === 'rating') {
                    return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
                }
                if (val === 'price-asc') {
                    return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                }
                if (val === 'price-desc') {
                    return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                }
                return 0;
            });

            cols.forEach((col) => merchantGrid.appendChild(col));
        });
    }
</script>
</body>
</html>
