<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Checkout</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

<div class="main-box">
<!-- ── Main Content ──────────────────────────── -->
<div class="browse-page">

    <!-- Back link -->
    <a href="/customer/cart" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;display:inline-block;margin-bottom:20px;">
        <i class="bi bi-arrow-left me-1"></i>Back to Cart
    </a>

    <!-- Page title -->
    <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.5rem;color:var(--charcoal-gray-secondary);margin:0 0 20px;">
        <i class="bi bi-lock me-2" style="color:var(--burnt-orange-primary);"></i>Checkout
    </h1>

    <!-- Progress steps -->
    <div class="d-flex align-items-center gap-2 mb-4" style="font-family:'Poppins',sans-serif;font-size:0.82rem;">
        <span style="color:var(--burnt-orange-primary);font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Cart</span>
        <i class="bi bi-chevron-right" style="color:#ccc;font-size:12px;"></i>
        <span style="color:var(--burnt-orange-primary);font-weight:600;">Checkout</span>
        <i class="bi bi-chevron-right" style="color:#ccc;font-size:12px;"></i>
        <span style="color:#bbb;">Confirmation</span>
    </div>

    <div class="row g-4">

        <!-- ── Left: Checkout Forms ──────────────── -->
        <div class="col-lg-7">

            <!-- 1. Delivery Info -->
            <div class="checkout-card">
                <div class="checkout-section-label">
                    <i class="bi bi-geo-alt me-1"></i>Delivery Address
                </div>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">First Name</label>
                        <input type="text" class="form-control" value="User" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">Last Name</label>
                        <input type="text" class="form-control" value="X" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">Street Address</label>
                        <input type="text" class="form-control" value="1345 NE Colorado St" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">Apt / Suite <span style="font-weight:400;color:#999;">(optional)</span></label>
                        <input type="text" class="form-control" placeholder="Apt, suite, unit…" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-5">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">City</label>
                        <input type="text" class="form-control" value="Pullman" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-3">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">State</label>
                        <input type="text" class="form-control" value="WA" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-4">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">ZIP Code</label>
                        <input type="text" class="form-control" value="99163" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:600;">Phone Number</label>
                        <input type="tel" class="form-control" value="(509) 555-0182" style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-color:#ddd;">
                    </div>
                </div>
            </div>

            <!-- 2. Fulfillment Option -->
            <div class="checkout-card">
                <div class="checkout-section-label">
                    <i class="bi bi-bicycle me-1"></i>Fulfillment Option
                </div>

                <label class="fulfillment-option selected" onclick="selectFulfillment(this)">
                    <input type="radio" name="fulfillment" checked style="margin-top:3px;accent-color:var(--burnt-orange-primary);">
                    <div>
                        <div class="fulfillment-option-title"><i class="bi bi-bicycle me-1"></i>Delivery by Driver</div>
                        <div class="fulfillment-option-desc">Estimated arrival: 25–35 min · $2.99 delivery fee</div>
                    </div>
                </label>

                <label class="fulfillment-option" onclick="selectFulfillment(this)">
                    <input type="radio" name="fulfillment" style="margin-top:3px;accent-color:var(--burnt-orange-primary);">
                    <div>
                        <div class="fulfillment-option-title"><i class="bi bi-person-walking me-1"></i>Customer Pickup</div>
                        <div class="fulfillment-option-desc">Ready in ~15 min · No delivery fee · Pick up from cook's location</div>
                    </div>
                </label>
            </div>

            <!-- 3. Payment Method -->
            <div class="checkout-card">
                <div class="checkout-section-label">
                    <i class="bi bi-credit-card me-1"></i>Payment Method
                </div>

                <!-- Saved card option -->
                <div style="background:var(--cream-primary);border-radius:10px;padding:14px 16px;margin-bottom:14px;border:1.5px solid var(--burnt-orange-primary);">
                    <div class="d-flex align-items-center gap-3">
                        <input type="radio" name="payment" checked style="accent-color:var(--burnt-orange-primary);">
                        <i class="bi bi-credit-card-2-front" style="font-size:22px;color:var(--burnt-orange-primary);"></i>
                        <div>
                            <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.88rem;">Visa ending in ···· 4242</div>
                            <div style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#888;">Expires 08/28 · Default card</div>
                        </div>
                        <span class="badge ms-auto" style="background:rgba(197,90,58,.1);color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-size:0.7rem;">Saved</span>
                    </div>
                </div>

                <!-- New card option -->
                <div style="border:1.5px solid #e4e4e4;border-radius:10px;padding:14px 16px;">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <input type="radio" name="payment" style="accent-color:var(--burnt-orange-primary);">
                        <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.88rem;color:var(--charcoal-gray-secondary);">
                            <i class="bi bi-plus-circle me-1"></i>Add New Card
                        </div>
                    </div>
                    <div class="row g-2" style="opacity:0.4;pointer-events:none;">
                        <div class="col-12">
                            <input type="text" class="form-control form-control-sm" placeholder="Card number" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;border-color:#ddd;">
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" placeholder="MM / YY" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;border-color:#ddd;">
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" placeholder="CVV" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;border-color:#ddd;">
                        </div>
                        <div class="col-12">
                            <input type="text" class="form-control form-control-sm" placeholder="Name on card" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;border-color:#ddd;">
                        </div>
                    </div>
                </div>
            </div>

        </div><!-- /left column -->

        <!-- ── Right: Order Summary ──────────────── -->
        <div class="col-lg-5">
            <div class="order-summary-box">
                <div class="order-summary-title"><i class="bi bi-receipt me-1"></i>Order Summary</div>

                <div id="checkout-merchant" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:600;color:var(--charcoal-gray-secondary);margin-bottom:12px;">
                    <i class="bi bi-house-heart me-1" style="color:var(--burnt-orange-primary);"></i>
                </div>

                <!-- Items -->
                <div id="checkout-items" style="font-family:'Open Sans',sans-serif;font-size:0.83rem;color:#555;margin-bottom:14px;"></div>

                <hr style="border-color:#f0e8d8;">

                <!-- Promo code -->
                <div class="d-flex gap-2 mb-3">
                    <input type="text" class="form-control form-control-sm" placeholder="Promo / discount code"
                        style="font-family:'Open Sans',sans-serif;font-size:0.85rem;border-color:#ddd;">
                    <button class="btn btn-sm btn-hp-outline" style="white-space:nowrap;font-size:0.82rem;padding:5px 14px;">Apply</button>
                </div>

                <div class="order-summary-row"><span>Subtotal</span><span id="checkout-subtotal">$0.00</span></div>
                <div class="order-summary-row"><span>Delivery fee</span><span id="checkout-delivery">$0.00</span></div>
                <div class="order-summary-row"><span>Tax (8.9%)</span><span id="checkout-tax">$0.00</span></div>
                <div class="order-summary-row total"><span>Total</span><span id="checkout-total">$0.00</span></div>

                <!-- ETA -->
                <div style="background:var(--cream-primary);border-radius:8px;padding:10px 14px;margin-top:14px;font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#555;">
                    <i class="bi bi-clock me-1" style="color:var(--burnt-orange-primary);"></i>
                    Estimated delivery: <strong>25–35 min</strong> after confirmation
                </div>

                <!-- Place Order -->
                <button id="place-order-btn" class="btn btn-hp w-100 mt-3" style="padding:13px;font-size:0.95rem;">
                  <i class="bi bi-lock me-1"></i>Place Order
                </button>

                <div style="text-align:center;font-family:'Open Sans',sans-serif;font-size:0.75rem;color:#aaa;margin-top:10px;">
                    <i class="bi bi-shield-check me-1"></i>Payment secured by 256-bit SSL encryption
                </div>
            </div>
        </div><!-- /order summary -->

    </div><!-- /row -->
</div><!-- /browse-page -->

</div><!-- /main-box -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
const cart = JSON.parse(localStorage.getItem("cart"));

function renderCheckout() {
    if (!cart) return;

    document.getElementById("checkout-merchant").innerHTML =
        `<i class="bi bi-house-heart me-1" style="color:var(--burnt-orange-primary);"></i>${cart.merchantName}`;

    const itemsHTML = cart.items.map(item => `
        <div class="d-flex justify-content-between mb-1">
            <span>${item.name} ×${item.quantity}</span>
            <span>$${(item.price * item.quantity).toFixed(2)}</span>
        </div>
    `).join("");
    document.getElementById("checkout-items").innerHTML = itemsHTML;

    const subtotal = cart.items.reduce((sum, i) => sum + i.price * i.quantity, 0);
    const tax = subtotal * 0.089;
    const delivery = 2.99;
    const total = subtotal + tax + delivery;

    document.getElementById("checkout-subtotal").textContent = `$${subtotal.toFixed(2)}`;
    document.getElementById("checkout-tax").textContent = `$${tax.toFixed(2)}`;
    document.getElementById("checkout-delivery").textContent = `$${delivery.toFixed(2)}`;
    document.getElementById("checkout-total").textContent = `$${total.toFixed(2)}`;

    document.getElementById("place-order-btn").innerHTML =
        `<i class="bi bi-lock me-1"></i>Place Order — $${total.toFixed(2)}`;
}

renderCheckout();
</script>
<script>
document.getElementById("place-order-btn").addEventListener("click", async () => {
    const cart = JSON.parse(localStorage.getItem("cart"));
    if (!cart || !cart.items || cart.items.length === 0) return;

    const response = await fetch("/customer/checkout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
            merchantId: cart.merchantId,
            items: cart.items
        })
    });

    const data = await response.json();

    if (data.success) {
        localStorage.removeItem("cart");
        window.location.href = `/customer/order-confirmation?orderId=${data.order.orderId}`;
    }
});
</script>

<script>
function selectFulfillment(label) {
    document.querySelectorAll('.fulfillment-option').forEach(el => el.classList.remove('selected'));
    label.classList.add('selected');
}
</script>
<script src="/javascripts/common-elements.js"></script>
</body>
</html>
