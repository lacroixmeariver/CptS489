<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Your Cart</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body data-role="<%= user.Role %>" data-user="<%= user.first_name %>">

<div class="main-box">
<!-- ── Main Content ──────────────────────────── -->
<div class="browse-page">

    <!-- Back link -->
    <a href="##" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;display:inline-block;margin-bottom:20px;">
        <i class="bi bi-arrow-left me-1"></i>Back to Restaurant
    </a>

    <!-- Page title -->
    <div class="mb-4">
        <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.5rem;color:var(--charcoal-gray-secondary);margin:0 0 4px;">
            Your Cart
        </h1>
        <div style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;">
            <i class="bi bi-house-heart me-1"></i>Grandma Maria's Kitchen
        </div>
    </div>

    <div class="row g-4">

        <!-- ── Cart Items Column ─────────────────── -->
        <div class="col-lg-7">
            <div style="background:#fff;border-radius:12px;padding:22px 24px;box-shadow:0 2px 8px rgba(0,0,0,0.07);">

                <!-- Item 1 -->
                <div class="cart-page-item">
                    <div class="cart-page-item-img" style="background:#f5ede0;"></div>
                    <div class="flex-grow-1">
                        <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.92rem;color:var(--charcoal-gray-secondary);">Grandma's Lasagna</div>
                        <div style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#888;margin-top:2px;">Classic 3-layer lasagna with house-made Bolognese</div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="qty-controls">
                            <button class="qty-btn">−</button>
                            <span class="qty-num">1</span>
                            <button class="qty-btn">+</button>
                        </div>
                        <div style="font-family:'Poppins',sans-serif;font-weight:700;font-size:0.92rem;color:var(--burnt-orange-primary);min-width:52px;text-align:right;">$18.00</div>
                        <button class="btn btn-sm" style="color:#ccc;border:none;background:none;padding:4px 6px;" title="Remove">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>

                <!-- Item 2 -->
                <div class="cart-page-item">
                    <div class="cart-page-item-img" style="background:#f0e8d8;"></div>
                    <div class="flex-grow-1">
                        <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.92rem;color:var(--charcoal-gray-secondary);">Tiramisu</div>
                        <div style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#888;margin-top:2px;">Classic espresso-soaked ladyfingers with mascarpone cream</div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="qty-controls">
                            <button class="qty-btn">−</button>
                            <span class="qty-num">2</span>
                            <button class="qty-btn">+</button>
                        </div>
                        <div style="font-family:'Poppins',sans-serif;font-weight:700;font-size:0.92rem;color:var(--burnt-orange-primary);min-width:52px;text-align:right;">$18.00</div>
                        <button class="btn btn-sm" style="color:#ccc;border:none;background:none;padding:4px 6px;" title="Remove">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>

                <!-- Item 3 -->
                <div class="cart-page-item" style="border-bottom:none;">
                    <div class="cart-page-item-img" style="background:#f5f0e8;"></div>
                    <div class="flex-grow-1">
                        <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.92rem;color:var(--charcoal-gray-secondary);">Honey Lemon Tart</div>
                        <div style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#888;margin-top:2px;">Buttery shortcrust shell with silky lemon curd</div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="qty-controls">
                            <button class="qty-btn">−</button>
                            <span class="qty-num">1</span>
                            <button class="qty-btn">+</button>
                        </div>
                        <div style="font-family:'Poppins',sans-serif;font-weight:700;font-size:0.92rem;color:var(--burnt-orange-primary);min-width:52px;text-align:right;">$8.00</div>
                        <button class="btn btn-sm" style="color:#ccc;border:none;background:none;padding:4px 6px;" title="Remove">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>

                <!-- Add More -->
                <div class="mt-3 pt-3" style="border-top:1px dashed #e4e4e4;">
                    <a href="restaurant-detail.html" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:600;color:var(--burnt-orange-primary);text-decoration:none;">
                        <i class="bi bi-plus-circle me-1"></i>Add more items
                    </a>
                </div>

            </div>

            <!-- Special Instructions -->
            <div style="background:#fff;border-radius:12px;padding:20px 24px;box-shadow:0 2px 8px rgba(0,0,0,0.07);margin-top:16px;">
                <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.88rem;color:var(--charcoal-gray-secondary);margin-bottom:10px;">
                    <i class="bi bi-chat-left-text me-1"></i>Special Instructions
                </div>
                <textarea class="form-control" rows="2" placeholder="Any allergies or special requests for the cook? (optional)"
                    style="font-family:'Open Sans',sans-serif;font-size:0.86rem;border-color:#e4e4e4;resize:none;"></textarea>
            </div>

        </div><!-- /cart items -->

        <!-- ── Order Summary ──────────────────────── -->
        <div class="col-lg-5">
            <div class="order-summary-box">
                <div class="order-summary-title"><i class="bi bi-receipt me-1"></i>Order Summary</div>

                <!-- Restaurant -->
                <div style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:600;color:var(--charcoal-gray-secondary);margin-bottom:12px;">
                    <i class="bi bi-house-heart me-1" style="color:var(--burnt-orange-primary);"></i>Grandma Maria's Kitchen
                </div>

                <!-- Items summary -->
                <div style="font-family:'Open Sans',sans-serif;font-size:0.83rem;color:#555;margin-bottom:14px;">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Grandma's Lasagna ×1</span><span>$18.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Tiramisu ×2</span><span>$18.00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Honey Lemon Tart ×1</span><span>$8.00</span>
                    </div>
                </div>

                <hr style="border-color:#f0e8d8;">

                <!-- Promo code -->
                <div class="d-flex gap-2 mb-3">
                    <input type="text" class="form-control form-control-sm" placeholder="Promo code"
                        style="font-family:'Open Sans',sans-serif;font-size:0.85rem;border-color:#ddd;">
                    <button class="btn btn-sm btn-hp-outline" style="white-space:nowrap;font-size:0.82rem;padding:6px 14px;">Apply</button>
                </div>

                <div class="order-summary-row"><span>Subtotal (4 items)</span><span>$44.00</span></div>
                <div class="order-summary-row"><span>Delivery fee</span><span>$2.99</span></div>
                <div class="order-summary-row"><span>Tax (8.9%)</span><span>$3.91</span></div>
                <div class="order-summary-row"><span style="color:var(--sage-green-secondary);"><i class="bi bi-tag me-1"></i>Promo</span><span style="color:var(--sage-green-secondary);">–$0.00</span></div>
                <div class="order-summary-row total"><span>Total</span><span>$50.90</span></div>

                <a href="/customer/checkout" class="btn btn-hp w-100 mt-3" style="padding:12px;">
                    <i class="bi bi-lock me-1"></i>Proceed to Checkout
                </a>

                <div style="text-align:center;font-family:'Open Sans',sans-serif;font-size:0.76rem;color:#aaa;margin-top:10px;">
                    <i class="bi bi-shield-check me-1"></i>Secure checkout · No surprise fees
                </div>
            </div>

            <!-- ETA Info -->
            <div style="background:var(--cream-primary);border-radius:12px;padding:16px 18px;margin-top:16px;border:1px solid #eadfc8;">
                <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.88rem;color:var(--charcoal-gray-secondary);margin-bottom:6px;">
                    <i class="bi bi-clock me-1" style="color:var(--burnt-orange-primary);"></i>Estimated Delivery
                </div>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.84rem;color:#555;">
                    Today, approx. <strong>7:45 PM</strong> (25–35 min after the cook confirms)
                </div>
            </div>
        </div><!-- /order summary -->

    </div><!-- /row -->
</div><!-- /browse-page -->

</div><!-- /main-box -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/common-elements.js"></script>
</body>
</html>
