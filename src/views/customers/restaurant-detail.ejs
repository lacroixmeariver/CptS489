<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — <%= merchant.MerchantName %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

<div class="main-box">
<!-- ── Back breadcrumb ────────────────────────── -->
<div style="background:var(--cream-primary);padding:10px 32px;border-bottom:1px solid #eadfc8;">
    <a href="/customer/browse" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;">
        <i class="bi bi-arrow-left me-1"></i>Back to Browse
    </a>
</div>

<!-- ── Restaurant Profile Banner ─────────────── -->
<div class="restaurant-profile-banner"<% if (merchant.storeImage) { %> style="background:linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.45)),url('<%= merchant.storeImage %>') center/cover no-repeat;"<% } %>>
    <div style="max-width:1200px;margin:0 auto;">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <!-- Cook avatar -->
            <div style="width:80px;height:80px;border-radius:16px;background:rgba(255,255,255,.15);overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-weight:700;font-size:2.2rem;color:#fff;flex-shrink:0;">
                <% if (merchant.storeImage) { %>
                    <img src="<%= merchant.storeImage %>" alt="<%= merchant.name %>" style="width:100%;height:100%;object-fit:cover;">
                <% } else { %>
                    <%= merchant.name.charAt(0) %>
                <% } %>
            </div>
            <!-- Info -->
            <div class="flex-grow-1">
                <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.5rem;color:#fff;margin:0 0 4px;">
                    <%= merchant.name %>
                </h1>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:rgba(255,255,255,.8);margin-bottom:10px;">
                    Home-cooked meals by <%= merchant.name %>
                </div>
                <div class="d-flex flex-wrap gap-3" style="font-family:'Open Sans',sans-serif;font-size:0.83rem;color:rgba(255,255,255,.85);">
                    <span><i class="bi bi-star-fill me-1" style="color:var(--golden-yellow-secondary);"></i><%= merchant.storeScore %> (<%= reviews.length %>)</span>
                </div>
            </div>
        </div>

        <!-- Bio -->
        <% if (merchant.bio) { %>
        <p style="font-family:'Open Sans',sans-serif;font-size:0.86rem;color:rgba(255,255,255,.75);margin:16px 0 0;max-width:700px;line-height:1.6;">
            <%= merchant.bio %>
        </p>
        <% } %>
    </div>
</div>

<!-- ── Main Content ──────────────────────────── -->
<div style="max-width:1200px;margin:0 auto;padding:28px 24px;">
    <div class="row g-4">

        <!-- ── Menu Column ─────────────────────── -->
        <div class="col-lg-8">
        <% if (menuItems.length === 0) { %>
            <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                <i class="bi bi-card-list" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
                <div>Menu is being prepared. Check back soon!</div>
            </div>
        <% } else { %>
            <% menuItems.forEach(item => { %>
                <div class="menu-item-card">
                    <div class="menu-item-img" style="background:#f5ede0;<% if (item.imagePath) { %>background-image:url('<%= item.imagePath %>');background-size:cover;background-position:center;<% } %>"></div>
                    <div class="menu-item-info">
                        <div class="menu-item-name"><%= item.name %></div>
                        <div class="menu-item-desc"><%= item.description %></div>
                        <div class="menu-item-price">$<%= item.price.toFixed(2) %></div>
                    </div>
                </div>

                <!-- Bio -->
                <% if (merchant.bio) { %>
                    <p
                        style="font-family:'Open Sans',sans-serif;font-size:0.86rem;color:rgba(255,255,255,.75);margin:16px 0 0;max-width:700px;line-height:1.6;">
                        <%= merchant.bio %>
                    </p>
                    <% } %>
            </div>
        </div>

        <!-- ── Main Content ──────────────────────────── -->
        <div style="max-width:1200px;margin:0 auto;padding:28px 24px;">
            <div class="row g-4">

                <!-- ── Back breadcrumb ────────────────────────── -->
                <div style="background:var(--cream-primary);padding:10px 32px;border-bottom:1px solid #eadfc8;">
                    <a href="/customer/browse"
                        style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;">
                        <i class="bi bi-arrow-left me-1"></i>Back to Browse
                    </a>
                </div>
                <!-- ── Menu Column ─────────────────────── -->
                <div class="col-lg-8">
                    <% if (menuItems.length===0) { %>
                        <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                            <i class="bi bi-card-list" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
                            <div>Menu is being prepared. Check back soon!</div>
                        </div>
                        <% } else { %>
                            <% menuItems.forEach(item=> { %>
                                <div class="menu-item-card">
                                    <div class="menu-item-img" style="background:#f5ede0;"></div>
                                    <div class="menu-item-info">
                                        <div class="menu-item-name">
                                            <%= item.name %>
                                        </div>
                                        <div class="menu-item-desc">
                                            <%= item.description %>
                                        </div>
                                        <div class="menu-item-price">$<%= item.price.toFixed(2) %>
                                        </div>
                                    </div>
                                    <button class="menu-item-add"
                                        onclick="addToCart('<%= item.itemId %>', '<%= item.name %>', <%= item.price %>)">
                                        <i class="bi bi-plus me-1"></i>Add
                                    </button>
                                </div>
                                <% }); %>
                                    <% } %>
                </div>

                <h3 class="mt-4" style="font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 1.25rem;">
                    Reviews</h3>
                <% if (reviews.length===0) { %>
                    <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                        <i class="bi bi-star" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
                        <div>No reviews yet. Be the first to review <%= merchant.name %>!</div>
                    </div>
                    <% } else { %>
                        <% reviews.forEach(review=> { %>
                            <div class="review-card">
                                <div class="review-header">
                                    <span class="review-rating">⭐ <%= review.Rating %></span>
                                    <span class="reviewer-name">
                                        <%= review.CustomerName %>
                                    </span>
                                    <span class="review-date">
                                        <%= review.ReviewDate ? new Date(review.ReviewDate).toLocaleDateString('en-US',
                                            {year:'numeric',month:'short',day:'numeric'}) : '' %>
                                    </span>
                                </div>
                                <div class="review-content">
                                    <p>
                                        <%= review.Comment || '' %>
                                    </p>
                                </div>
                            </div>
                            <% }); %>
                                <% } %>

                                    <!-- ── Write a Review ──────────────────────── -->
                                    <div class="mt-4">
                                        <button class="btn btn-sm" id="btn-open-review"
                                            style="font-family:'Poppins',sans-serif;font-size:0.85rem;background:var(--burnt-orange-primary);color:#fff;border:none;border-radius:8px;padding:7px 18px;"
                                            onclick="document.getElementById('review-form-box').style.display='block';this.style.display='none';">
                                            <i class="bi bi-star me-1"></i>Write a Review
                                        </button>
                                        <div id="review-form-box"
                                            style="display:none;background:#fff;border-radius:12px;padding:20px 22px;margin-top:12px;box-shadow:0 2px 8px rgba(0,0,0,.07);max-width:520px;">
                                            <div
                                                style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.95rem;margin-bottom:12px;">
                                                Your Review</div>
                                            <div class="mb-3">
                                                <label
                                                    style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#777;display:block;margin-bottom:4px;">Rating</label>
                                                <div id="star-picker"
                                                    style="font-size:1.5rem;cursor:pointer;color:#ccc;user-select:none;">
                                                    <span data-v="1">★</span><span data-v="2">★</span><span
                                                        data-v="3">★</span><span data-v="4">★</span><span
                                                        data-v="5">★</span>
                                                </div>
                                                <input type="hidden" id="review-rating" value="0">
                                            </div>
                                            <div class="mb-3">
                                                <label
                                                    style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#777;display:block;margin-bottom:4px;">Comment
                                                    <span style="color:#bbb;">(optional)</span></label>
                                                <textarea id="review-comment" rows="3" class="form-control"
                                                    style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-radius:8px;border:1.5px solid #e8e8e8;resize:vertical;"></textarea>
                                            </div>
                                            <div id="review-error"
                                                style="font-size:0.82rem;color:#dc3545;margin-bottom:8px;display:none;">
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm"
                                                    style="background:var(--burnt-orange-primary);color:#fff;border:none;border-radius:8px;padding:6px 16px;font-family:'Poppins',sans-serif;font-size:0.85rem;"
                                                    onclick="submitReview(<%= merchant.merchantId %>)">Submit</button>
                                                <button class="btn btn-sm"
                                                    style="border:1.5px solid #ddd;background:transparent;border-radius:8px;padding:6px 14px;font-family:'Poppins',sans-serif;font-size:0.85rem;"
                                                    onclick="document.getElementById('review-form-box').style.display='none';document.getElementById('btn-open-review').style.display=''">Cancel</button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── Cart Widget Sidebar ──────────────── -->
                                    <div class="col-lg-4">
                                        <div class="cart-widget">
                                            <div class="cart-widget-title">
                                                <i class="bi bi-bag me-1"></i>Your Order
                                            </div>

                                            <!-- Empty state -->
                                            <div id="cart-empty" style="text-align:center;padding:20px 0;color:#bbb;">
                                                <i class="bi bi-bag"
                                                    style="font-size:32px;display:block;margin-bottom:8px;"></i>
                                                <div style="font-family:'Open Sans',sans-serif;font-size:0.85rem;">Your
                                                    cart is empty.</div>
                                                <div
                                                    style="font-family:'Open Sans',sans-serif;font-size:0.8rem;margin-top:4px;">
                                                    Add items from the menu to get started.</div>
                                            </div>

                                            <!-- Cart items (shown after adding) -->
                                            <div id="cart-items" style="display:none;"></div>

                                            <!-- Toggle demo button -->
                                            <button class="btn btn-hp-outline w-100 mt-3" style="font-size:0.82rem;"
                                                onclick="toggleCart()">
                                                <i class="bi bi-eye me-1"></i>
                                            </button>
                                            <a href="/customer/checkout" class="btn btn-hp w-100 mt-3"
                                                style="font-size:0.9rem;">
                                                <i class="bi bi-credit-card me-1"></i>Checkout
                                            </a>
                                        </div>

                                    </div><!-- /cart sidebar -->
            </div><!-- /row -->
        </div><!-- /main content -->

    </div><!-- /main-box -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ── Star picker ──────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            const stars = document.querySelectorAll('#star-picker span');
            const ratingInput = document.getElementById('review-rating');
            if (!stars.length) return;
            const paint = (n) => stars.forEach(s => s.style.color = parseInt(s.dataset.v) <= n ? 'var(--golden-yellow-secondary, #f5a623)' : '#ccc');
            stars.forEach(s => {
                s.addEventListener('mouseover', () => paint(parseInt(s.dataset.v)));
                s.addEventListener('mouseleave', () => paint(parseInt(ratingInput.value)));
                s.addEventListener('click', () => { ratingInput.value = s.dataset.v; paint(parseInt(s.dataset.v)); });
            });
        });

        function submitReview(merchantId) {
            const rating = parseInt(document.getElementById('review-rating').value);
            const comment = document.getElementById('review-comment').value.trim();
            const errEl = document.getElementById('review-error');
            errEl.style.display = 'none';
            if (!rating) { errEl.textContent = 'Please select a star rating.'; errEl.style.display = 'block'; return; }
            fetch(`/customer/merchant/${merchantId}/review`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rating, comment })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.ok) { location.reload(); }
                    else { errEl.textContent = data.error || 'Failed to submit review.'; errEl.style.display = 'block'; }
                })
                .catch(() => { errEl.textContent = 'Network error. Please try again.'; errEl.style.display = 'block'; });
        }

        // ── Cart ─────────────────────────────────────────────────────
        let cart = loadCart();

        function loadCart() {
            const saved = localStorage.getItem("cart");
            return saved ? JSON.parse(saved) : {
                merchantId: <%= merchant.merchantId %>,
                merchantName: "<%= merchant.name %>",
                items: []
            };
        }

        function saveCart() {
            localStorage.setItem("cart", JSON.stringify(cart));
        }

        function addToCart(id, name, price) {
            if (cart.merchantId !== <%= merchant.merchantId %>) {
                cart = {
                    merchantId: <%= merchant.merchantId %>,
                    merchantName: "<%= merchant.name %>",
                    items: []
                };
            }

            const existing = cart.items.find(i => i.itemId === id);
            if (existing) {
                existing.quantity++;
            } else {
                cart.items.push({
                    itemId: id,
                    name,
                    price: Number(price),
                    quantity: 1
                });
            }

            saveCart();
            renderCart();

        }

        function removeFromCart(id) {
            cart.items = cart.items.filter(i => i.itemId !== id);
            saveCart();
            renderCart();
        }

        function renderCart() {
            const empty = document.getElementById('cart-empty');
            const items = document.getElementById('cart-items');

            if (cart.items.length === 0) {
                empty.style.display = 'block';
                items.style.display = 'none';
                items.innerHTML = '';
                return;
            }

            empty.style.display = 'none';
            items.style.display = 'block';

            items.innerHTML = cart.items.map(item => `
        <div class="cart-item-row">
            <span class="cart-qty-btn" onclick="decreaseQty('${item.itemId}')">-</span>
            <span class="cart-item-name">${item.name} x${item.quantity}</span>
            <span class="cart-qty-btn" onclick="increaseQty('${item.itemId}')">+</span>
            <span class="cart-item-price">$${(item.price * item.quantity).toFixed(2)}</span>
            <span class="cart-remove-btn" onclick="removeFromCart('${item.itemId}')"><i class="bi bi-x"></i></span>
        </div>
    `).join('');
        }

        function increaseQty(id) {
            const item = cart.items.find(i => i.itemId === id);
            if (item) {
                item.quantity++;
                saveCart();
                renderCart();
            }
        }

        function decreaseQty(id) {
            const item = cart.items.find(i => i.itemId === id);
            if (item && item.quantity > 1) {
                item.quantity--;
            } else {
                removeFromCart(id);
                return;
            }

            saveCart();
            renderCart();
        }

        function toggleCart() {
            const empty = document.getElementById('cart-empty');
            const items = document.getElementById('cart-items');

            if (items.style.display === 'none') {
                empty.style.display = cart.items.length === 0 ? 'block' : 'none';
                items.style.display = cart.items.length === 0 ? 'none' : 'block';
            } else {
                empty.style.display = 'block';
                items.style.display = 'none';
            }
        }

        renderCart();
    </script>
    <script src="/javascripts/common-elements.js"></script>
</body>

</html>