<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Order Confirmed!</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body data-role="<%= user.role %>" data-user="<%= user.first_name %>">

<div class="main-box">
<!-- ── Confirmation Card ──────────────────────── -->
<div class="browse-page">
    <div class="confirmation-card">

        <!-- Success icon -->
        <div class="confirmation-icon">
            <i class="bi bi-check-lg"></i>
        </div>

        <!-- Heading -->
        <h2 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.4rem;color:var(--charcoal-gray-secondary);margin-bottom:6px;">
            Order Confirmed!
        </h2>
        <p style="font-family:'Open Sans',sans-serif;font-size:0.9rem;color:#888;margin-bottom:24px;">
            Your order has been sent to <strong>Grandma Maria's Kitchen</strong>.<br>
            You'll receive a notification once the cook confirms.
        </p>

        <!-- Order details -->
        <div style="background:var(--cream-primary);border-radius:10px;padding:16px 20px;margin-bottom:24px;text-align:left;">

            <div class="confirmation-detail-row">
                <span style="color:#888;">Order Number</span>
                <strong style="font-family:'Poppins',sans-serif;">#HP-20260306-2088</strong>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Restaurant</span>
                <span>Grandma Maria's Kitchen</span>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Items</span>
                <span>Lasagna, Tiramisu ×2, Tart</span>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Total Paid</span>
                <strong style="font-family:'Poppins',sans-serif;color:var(--burnt-orange-primary);">$50.90</strong>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Payment</span>
                <span>Visa ···· 4242</span>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Delivery Address</span>
                <span>1345 NE Colorado St, Pullman, WA</span>
            </div>
        </div>

        <!-- ETA banner -->
        <div style="background:rgba(197,90,58,.06);border:1.5px solid rgba(197,90,58,.2);border-radius:10px;padding:14px 18px;margin-bottom:28px;display:flex;align-items:center;gap:14px;text-align:left;">
            <i class="bi bi-alarm" style="font-size:28px;color:var(--burnt-orange-primary);flex-shrink:0;"></i>
            <div>
                <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.95rem;color:var(--charcoal-gray-secondary);">
                    Estimated Arrival: <span style="color:var(--burnt-orange-primary);">7:45 PM</span>
                </div>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;">
                    About 25–35 min after the cook starts preparing
                </div>
            </div>
        </div>

        <!-- CTA Buttons -->
        <div class="d-flex flex-column gap-2">
            <a href="customer-dashboard.html" class="btn btn-hp" style="padding:12px;font-size:0.92rem;">
                <i class="bi bi-bicycle me-1"></i>Track My Order
            </a>
            <a href="browse.html" class="btn btn-hp-outline" style="padding:11px;font-size:0.88rem;">
                <i class="bi bi-search me-1"></i>Continue Browsing
            </a>
        </div>

        <p style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#bbb;margin-top:20px;margin-bottom:0;">
            A confirmation has been sent to your registered email address.
        </p>
    </div>
</div><!-- /browse-page -->

</div><!-- /main-box -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/common-elements.js"></script>
</body>
</html>
