<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — My Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-dashboard.css">
</head>

<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

    <div class="main-box">
        <main class="main-content">

        <!-- Page header + avatar -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="profile-avatar" id="profile-avatar-wrap">
                <% if (user.Role === 'vendor' && extra && extra.StoreImage) { %>
                    <img src="<%= extra.StoreImage %>" alt="Store photo" id="avatar-store-img" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
                <% } else { %>
                    <span id="avatar-initials"><%= user.First_name.charAt(0) %><%= user.Last_name.charAt(0) %></span>
                <% } %>
                <% if (user.Role === 'vendor') { %>
                    <input type="file" id="avatarFileInput" name="storeImage" accept="image/jpeg,image/png,image/webp" style="display:none;">
                    <div class="avatar-edit-btn" title="Change store photo" onclick="document.getElementById('avatarFileInput').click()"><i class="bi bi-camera-fill"></i></div>
                <% } else { %>
                    <div class="avatar-edit-btn" title="Change photo"><i class="bi bi-camera-fill"></i></div>
                <% } %>
            </div>
            <div>
                <h1 id="header-name" style="font-family:'Poppins',sans-serif;font-size:1.5rem;font-weight:700;color:var(--charcoal-gray-secondary);margin:0;">
                    <%= user.First_name %> <%= user.Last_name %>
                </h1>
                <span style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#999;">
                    <%= user.Role === 'vendor' ? 'Merchant account' : 'Customer account' %>
                </span>
                <% if (user.Role === 'vendor' && extra) { %>
                <% const vs = extra.Verified || 'Pending'; %>
                <span style="display:inline-block;margin-top:4px;font-family:'Open Sans',sans-serif;font-size:0.78rem;font-weight:600;padding:2px 10px;border-radius:20px;
                    background:<%= vs==='Approved' ? 'rgba(22,163,74,0.12)' : vs==='Rejected' ? 'rgba(220,38,38,0.12)' : 'rgba(202,138,4,0.15)' %>;
                    color:<%= vs==='Approved' ? '#15803d' : vs==='Rejected' ? '#dc2626' : '#92400e' %>;">
                    <i class="bi bi-<%= vs==='Approved' ? 'patch-check-fill' : vs==='Rejected' ? 'x-circle-fill' : 'hourglass-split' %> me-1"></i>Verification: <%= vs %>
                </span>
                <% } %>
            </div>

        </div>

        <div class="row g-4">
            <!-- ─── Left column: personal info ─── -->
            <div class="col-lg-7">

                <div class="profile-card mb-4">
                    <div class="profile-section-title">
                        <i class="bi bi-person"></i> Personal Information
                    </div>

                    <div class="row g-3" id="view-mode">
                        <div class="col-6">
                            <div class="profile-field">
                                <div class="profile-field-label">First Name</div>
                                <div class="profile-field-value" id="vw-first"><%= user.First_name %></div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="profile-field">
                                <div class="profile-field-label">Last Name</div>
                                <div class="profile-field-value" id="vw-last"><%= user.Last_name %></div>
                            </div>
                        </div>
                        <% if (user.Role === 'vendor') { %>
                        <div class="col-12">
                            <div class="profile-field">
                                <div class="profile-field-label">Store Name</div>
                                <div class="profile-field-value" id="vw-storename"><%= extra?.MerchantName || '' %></div>
                            </div>
                        </div>
                        <% } %>
                        <div class="col-12">
                            <div class="profile-field">
                                <div class="profile-field-label">Email Address</div>
                                <div class="profile-field-value" id="vw-email"><%= user.Email %></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="profile-field">
                                <div class="profile-field-label">Phone Number</div>
                                <div class="profile-field-value" id="vw-phone"><%= user.Phone_number || '—' %></div>
                            </div>
                        </div>
                        <div class="col-12 mt-1">
                            <button class="btn-hp-outline-edit" id="btn-edit" onclick="enterEditMode()">
                                <i class="bi bi-pencil me-1"></i>Edit Profile
                            </button>
                        </div>
                    </div>

                    <!-- Edit mode (hidden by default) -->
                    <div id="edit-mode" style="display:none;">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="profile-field-label mb-1" for="ed-first">First Name</label>
                                <input type="text" id="ed-first" class="form-control profile-input" value="<%= user.First_name %>">
                            </div>
                            <div class="col-md-6">
                                <label class="profile-field-label mb-1" for="ed-last">Last Name</label>
                                <input type="text" id="ed-last" class="form-control profile-input" value="<%= user.Last_name %>">
                            </div>
                            <% if (user.Role === 'vendor') { %>
                            <div class="col-12">
                                <label class="profile-field-label mb-1" for="ed-storename">Store Name</label>
                                <input type="text" id="ed-storename" class="form-control profile-input" value="<%= extra?.MerchantName || '' %>">
                            </div>
                            <% } %>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button class="btn-hp-edit" onclick="saveChanges()">
                                <i class="bi bi-check2 me-1"></i>Save Changes
                            </button>
                            <button class="btn-hp-outline-edit" onclick="cancelEdit()">Cancel</button>
                        </div>
                    </div>
                </div>

                    <!-- ── Change Password ── -->
                    <div class="pwd-section mt-4" id="pwd-accordion">
                        <div class="pwd-toggle-header" onclick="togglePwd()">
                            <div class="profile-section-title mb-0">
                                <i class="bi bi-lock"></i> Change Password
                            </div>
                            <i class="bi bi-chevron-down" id="pwd-chevron"></i>
                        </div>
                        <div class="pwd-body" id="pwd-body" style="display:none;">
                            <% if (locals.pwdError) { %>
                                <div class="alert alert-danger py-2 mb-3" style="font-size:0.85rem;border-radius:8px;">
                                    <i class="bi bi-exclamation-circle me-1"></i>
                                    <%= pwdError %>
                                </div>
                                <% } %>
                                    <form method="POST" action="profile/password" autocomplete="off">
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="profile-field-label mb-1" for="pwd-current">Current
                                                    Password</label>
                                                <input type="password" id="pwd-current" name="currentPassword"
                                                    autocomplete="off" class="form-control profile-input"
                                                    placeholder="Enter current password">

                                            </div>
                                            <div class="col-md-4">
                                                <label class="profile-field-label mb-1" for="pwd-new">New
                                                    Password</label>
                                                <input type="password" id="pwd-new" name="newPassword"
                                                    class="form-control profile-input"
                                                    placeholder="New password (min 8 chars)">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="profile-field-label mb-1" for="pwd-confirm">Confirm
                                                    New</label>
                                                <input type="password" id="pwd-confirm" name="confirmPassword"
                                                    class="form-control profile-input"
                                                    placeholder="Repeat new password">
                                            </div>
                                        </div>
                                        <div id="pwd-client-error" class="mt-2"
                                            style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#dc3545;display:none;">
                                        </div>
                                        <div class="d-flex gap-2 mt-3">
                                            <button type="submit" class="btn-hp-edit" onclick="return validatePwd()">
                                                <i class="bi bi-lock-fill me-1"></i>Update Password
                                            </button>
                                        </div>
                                    </form>
                        </div>
                    </div>


                <!-- Address -->
                <div class="profile-card">
                    <div class="profile-section-title">
                        <i class="bi bi-geo-alt"></i> <%= user.Role === 'vendor' ? 'Store Address' : 'Default Delivery Address' %>
                    </div>

                    <div id="view-addr">
                        <div class="profile-field">
                            <div class="profile-field-label">Address</div>
                            <div class="profile-field-value" id="vw-addr"><%= extra?.MerchantAddress || extra?.Address || 'Not set' %></div>
                        </div>
                        <button class="btn-hp-outline-edit mt-3" onclick="toggleAddrEdit(true)">
                            <i class="bi bi-pencil me-1"></i>Edit Address
                        </button>
                    </div>

                    <div id="edit-addr" style="display:none;">
                        <div class="mb-3">
                            <label class="profile-field-label mb-1" for="ed-street">Address</label>
                            <input type="text" id="ed-street" class="form-control profile-input"
                                value="<%= extra?.MerchantAddress || extra?.Address || '' %>">
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn-hp-edit" onclick="saveAddr()">
                                <i class="bi bi-check2 me-1"></i>Save Address
                            </button>
                            <button class="btn-hp-outline-edit" onclick="toggleAddrEdit(false)">Cancel</button>
                        </div>
                    </div>
                </div>

                <% if (user.Role === 'vendor') { %>
                <div class="profile-card mt-3">
                    <div class="profile-section-title">
                        <i class="bi bi-image"></i> Store Photo
                    </div>
                    <% if (extra && extra.StoreImage) { %>
                        <img src="<%= extra.StoreImage %>" alt="Store photo" style="max-width:100%;max-height:220px;object-fit:cover;border-radius:8px;margin-bottom:12px;" id="storeImagePreview">
                    <% } else { %>
                        <p class="text-muted mb-2" id="noStoreImageMsg">No store photo uploaded yet.</p>
                        <img src="" alt="Store photo" id="storeImagePreview" style="display:none;max-width:100%;max-height:220px;object-fit:cover;border-radius:8px;margin-bottom:12px;">
                    <% } %>
                    <div class="d-flex gap-2 align-items-center flex-wrap mt-1">
                        <label for="storeImageInput" class="btn-hp-edit" style="cursor:pointer;"><i class="bi bi-upload me-1"></i>Choose &amp; Upload Photo</label>
                        <input type="file" id="storeImageInput" accept="image/jpeg,image/png,image/webp" style="display:none;">
                        <small class="text-muted">jpg/png/webp, max 5MB</small>
                    </div>
                </div>
                <% } %>

                <% if (user.Role === 'vendor') { %>
                <div class="profile-card mt-3">
                    <div class="profile-section-title">
                        <i class="bi bi-chat-quote"></i> Store Bio
                    </div>

                    <div id="view-bio">
                        <div class="profile-field">
                            <div class="profile-field-label">Bio</div>
                            <div class="profile-field-value" id="vw-bio" style="white-space:pre-wrap;"><%= extra?.Bio || 'No bio yet.' %></div>
                        </div>
                        <button class="btn-hp-outline-edit mt-3" onclick="toggleBioEdit(true)">
                            <i class="bi bi-pencil me-1"></i>Edit Bio
                        </button>
                    </div>

                    <div id="edit-bio" style="display:none;">
                        <div class="mb-3">
                            <label class="profile-field-label mb-1" for="ed-bio">Bio</label>
                            <textarea id="ed-bio" class="form-control profile-input" rows="4" maxlength="400"
                                style="resize:vertical;"><%= extra?.Bio || '' %></textarea>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn-hp-edit" onclick="saveBio()">
                                <i class="bi bi-check2 me-1"></i>Save Bio
                            </button>
                            <button class="btn-hp-outline-edit" onclick="toggleBioEdit(false)">Cancel</button>
                        </div>
                    </div>
                </div>
                <% } %>

            </div>

            <!-- ─── Right column ─── -->
            <div class="col-lg-5 d-flex flex-column gap-4">

                <% if (user.Role === 'customer') { %>
                <!-- Payment methods -->
                <div class="profile-card">
                    <div class="profile-section-title">
                        <i class="bi bi-credit-card"></i> Payment Methods
                    </div>
                    <div class="d-flex align-items-center gap-3 mb-2 p-3 rounded"
                         style="border:1.5px solid #e8e8e8;">
                        <i class="bi bi-credit-card-2-front-fill" style="font-size:1.4rem;color:#555;"></i>
                        <div>
                            <div style="font-family:'Poppins',sans-serif;font-size:0.88rem;font-weight:600;color:var(--charcoal-gray-secondary);">
                                Visa ending in 4242
                            </div>
                            <div style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#aaa;">Expires 08/27</div>
                        </div>
                        <span class="ms-auto badge rounded-pill"
                              style="background:rgba(122,155,110,.15);color:var(--sage-green-secondary);font-family:'Poppins',sans-serif;font-size:0.72rem;">
                            Default
                        </span>
                    </div>

                    <!-- Add payment form (hidden until button clicked) -->
                    <div id="add-payment-form" style="display:none;margin-top:14px;border:1.5px solid #e8e8e8;border-radius:10px;padding:18px 16px;background:#fafafa;">
                        <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.9rem;color:var(--charcoal-gray-secondary);margin-bottom:14px;">
                            <i class="bi bi-credit-card me-2"></i>New Card
                        </div>

                        <!-- Card Number -->
                        <div class="mb-3">
                            <label class="profile-field-label mb-1" for="card-number">Card Number</label>
                            <input type="text" id="card-number" class="profile-input w-100"
                                placeholder="1234 5678 9012 3456">
                        </div>

                        <!-- Cardholder Name -->
                        <div class="mb-3">
                            <label class="profile-field-label mb-1" for="card-name">Cardholder Name</label>
                            <input type="text" id="card-name" class="profile-input w-100"
                                placeholder="Name as it appears on card" autocomplete="cc-name">
                        </div>

                        <!-- Expiration + CVV row -->
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="profile-field-label mb-1" for="card-expiry">Expiration Date</label>
                                <input type="text" id="card-expiry" class="profile-input w-100"
                                    placeholder="MM / YY">
                            </div>
                            <div class="col-6">
                                <label class="profile-field-label mb-1" for="card-cvv">CVV</label>
                                <input type="password" id="card-cvv" class="profile-input w-100"
                                    placeholder="•••" maxlength="4">
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn-hp-outline-edit" onclick="cancelPayment()">Cancel</button>
                            <button class="btn-hp-edit" onclick="savePayment()">
                                <i class="bi bi-check-lg me-1"></i>Save Card
                            </button>
                        </div>
                    </div>

                    <button class="btn-hp-outline-edit mt-2 w-100" id="btn-add-payment" onclick="togglePaymentForm()">
                        <i class="bi bi-plus me-1"></i>Add Payment Method
                    </button>
                </div>
                <% } %>

            </div>
        </div>

    </div>

    <script>
        // ── Edit / view toggle ──────────────────────────────
        function enterEditMode() {
            document.getElementById('view-mode').style.display = 'none';
            document.getElementById('edit-mode').style.display = 'block';
            document.getElementById('btn-edit').style.display = 'none';
        }
        function cancelEdit() {
            document.getElementById('view-mode').style.display = '';
            document.getElementById('edit-mode').style.display = 'none';
            document.getElementById('btn-edit').style.display = '';
        }

// ── Edit / view toggle ──────────────────────────────
function enterEditMode() {
    document.getElementById('view-mode').style.display = 'none';
    document.getElementById('edit-mode').style.display = 'block';
    document.getElementById('btn-edit').style.display = 'none';
}
function cancelEdit() {
    document.getElementById('view-mode').style.display = '';
    document.getElementById('edit-mode').style.display = 'none';
    document.getElementById('btn-edit').style.display = '';
}
function saveChanges() {
    const firstName = document.getElementById('ed-first').value.trim();
    const lastName  = document.getElementById('ed-last').value.trim();
    if (!firstName || !lastName) return;
    const role = '<%= user.Role %>';
    const url  = role === 'vendor' ? '/vendor/api/profile' : '/customer/api/profile';
    const payload = { firstName, lastName };
    if (role === 'vendor') {
        payload.storeName = document.getElementById('ed-storename').value.trim();
    }
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(r => r.json())
    .then(data => {
        if (data.ok) {
            document.getElementById('vw-first').textContent = firstName;
            document.getElementById('vw-last').textContent  = lastName;
            document.getElementById('header-name').textContent = firstName + ' ' + lastName;
            if (role === 'vendor') {
                document.getElementById('vw-storename').textContent = payload.storeName;
            }
            cancelEdit();
            showToast();
        }
    })
    .catch(() => {});
}

// ── Address edit ────────────────────────────────────
function toggleAddrEdit(show) {
    document.getElementById('view-addr').style.display = show ? 'none' : '';
    document.getElementById('edit-addr').style.display = show ? 'block' : 'none';
}
function saveAddr() {
    const address = document.getElementById('ed-street').value.trim();
    const role = '<%= user.Role %>';
    const url  = role === 'vendor' ? '/vendor/api/profile' : '/customer/api/profile';
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ address })
    })
    .then(r => r.json())
    .then(data => {
        if (data.ok) {
            document.getElementById('vw-addr').textContent = address || 'Not set';
            toggleAddrEdit(false);
            showToast();
        }
    })
    .catch(() => {});
}

// ── Bio edit ──────────────────────────────────────────
function toggleBioEdit(show) {
    document.getElementById('view-bio').style.display = show ? 'none' : '';
    document.getElementById('edit-bio').style.display = show ? 'block' : 'none';
}
function saveBio() {
    const bio = document.getElementById('ed-bio').value.trim();
    fetch('/vendor/api/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bio })
    })
    .then(r => r.json())
    .then(data => {
        if (data.ok) {
            document.getElementById('vw-bio').textContent = bio || 'No bio yet.';
            toggleBioEdit(false);
            showToast();
        }
    })
    .catch(() => {});
}


        // ── Toast notification ──────────────────────────────
        function showToast() {
            let toast = document.getElementById('save-toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'save-toast';
                toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#7a9b6e;color:#fff;font-family:Poppins,sans-serif;font-size:0.88rem;padding:10px 20px;border-radius:10px;z-index:9999;opacity:0;transition:opacity .3s;';
                toast.textContent = '✓ Changes saved';
                document.body.appendChild(toast);
            }
            toast.style.opacity = '1';
            setTimeout(() => { toast.style.opacity = '0'; }, 2500);
        }
        function toggleDriverEdit(show) {
            document.getElementById('view-driver').style.display = show ? 'none' : '';
            document.getElementById('edit-driver').style.display = show ? 'block' : 'none';
        }

        // ── Password accordion ──────────────────────────────
        function togglePwd() {
            const body = document.getElementById('pwd-body');
            const chevron = document.getElementById('pwd-chevron');
            const open = body.style.display !== 'none';
            body.style.display = open ? 'none' : 'block';
            chevron.className = open ? 'bi bi-chevron-down' : 'bi bi-chevron-up';
        }

        // Client-side validation — catches obvious mistakes before hitting the server
        function validatePwd() {
            const errEl = document.getElementById('pwd-client-error');
            const current = document.getElementById('pwd-current');
            const newPwd = document.getElementById('pwd-new').value;
            const confirm = document.getElementById('pwd-confirm').value;
            errEl.style.display = 'none';
            if (!current) {
                errEl.textContent = 'Please enter your current password.';
                errEl.style.display = 'block';
                return false;
            }
            if (newPwd.length < 8) {
                errEl.textContent = 'New password must be at least 8 characters.';
                errEl.style.display = 'block';
                return false;
            }
            if (newPwd !== confirm) {
                errEl.textContent = 'Passwords do not match.';
                errEl.style.display = 'block';
                return false;
            }
            return true;
        }

        // ── Delete modal ────────────────────────────────────
        function confirmDelete() {
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        // ── Store image upload (vendor) ─────────────────────
        <% if (user.Role === 'vendor') { %>
        function uploadStoreImage(file) {
            const formData = new FormData();
            formData.append('storeImage', file);
            fetch('/vendors/api/upload-store-image', { method: 'POST', body: formData })
                .then(r => r.json())
                .then(data => {
                    if (!data.ok) return;
                    const path = data.imagePath;
                    // Update store image preview card
                    const preview = document.getElementById('storeImagePreview');
                    const noMsg = document.getElementById('noStoreImageMsg');
                    if (preview) { preview.src = path; preview.style.display = ''; }
                    if (noMsg)  noMsg.style.display = 'none';
                    // Update avatar circle
                    const wrap = document.getElementById('profile-avatar-wrap');
                    let img = document.getElementById('avatar-store-img');
                    const initials = document.getElementById('avatar-initials');
                    if (!img) {
                        img = document.createElement('img');
                        img.id = 'avatar-store-img';
                        img.alt = 'Store photo';
                        img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:50%;';
                        wrap.insertBefore(img, wrap.firstChild);
                    }
                    img.src = path;
                    if (initials) initials.style.display = 'none';
                    showToast();
                })
                .catch(() => {});
        }
        document.addEventListener('DOMContentLoaded', () => {
            ['storeImageInput', 'avatarFileInput'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.addEventListener('change', e => {
                    if (e.target.files[0]) uploadStoreImage(e.target.files[0]);
                });
            });
        });
        <% } %>
    </script>

    <% if (locals.pwdError) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                document.getElementById('pwd-body').style.display = 'block';
                document.getElementById('pwd-chevron').className = 'bi bi-chevron-up';
            });
        </script>
        <% } %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/javascripts/common-elements.js"></script>
</body>

</html>