<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - User Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>

<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

    <!-- box for the main area (the entire visible screen aside from navbar basically) -->
    <div class="main-box">
        <!-- most of this content below is hard-coded dummy content (for now) -->

        <!-- container for main dashboard content -->
        <div class="container-fluid p-5 table-container">
            <div class="d-flex align-items-center mb-2">

                <h2>Manage Users</h2>

                <!-- user search form -->

                <form class="d-flex ms-auto align-items-center" id="search-form" action="/admins/manage-users"
                    method="GET">
                    <label for="userSearch"></label>
                    <input type="hidden" name="searchBy" id="searchBy" value="userId">
                    <input type="text" class="form-control mx-4" name="targetUser" placeholder="Search for a user">
                    <div class="btn-group" id="searchBtnGroup">
                        <button class="btn btn-primary btn-sm" id="searchBtn" type="submit">Search by user ID</button>
                        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split"
                            data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">Toggle Dropdown</span>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#" onclick="setSearchBy('userId', 'user ID')">User ID</a>
                            </li>
                            <li><a class="dropdown-item" href="#" onclick="setSearchBy('username', 'username')">User
                                    Name</a></li>
                            <li><a class="dropdown-item" href="#" onclick="setSearchBy('email', 'email')">Email</a></li>
                        </ul>

                    </div>

                </form>


            </div>

            <div class="text-end search-bar-info">
                <p class="">Search for a user by first name, user id, or email.</p>
            </div>

            <!-- tab headings to quickly switch between types of users -->
            <!-- they're currently linked to these hardcoded tables but we'll have to link them to the db when we set it up -->
            <ul class="nav nav-tabs" id="userTypeTabs" role="tablist">
                <li class="nav-item"> <!-- all users is always set to initial active tab -->
                    <a href="#allUsers" class="nav-link active" data-bs-toggle="tab" aria-current="page">All Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#regUsersTab">Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#vendorsTab">Vendors</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#driversTab">Drivers</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#adminTab">Administrators</a>
                </li>
            </ul>

            <% const statusMap={ 0: {label: 'Active' , class: 'status-active' }, 1: {label: 'Banned' ,
                class: 'status-banned' }, 2: {label: 'Suspended' , class: 'status-suspended' } } %>

                <!-- content/tables for each tab -->
                <div class="tab-content p-2">
                    <div class="tab-pane fade show active" id="allUsers">
                        <table class="table">
                            <!-- ALL USERS -->
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Email</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>

                                <% users.forEach(user=>{ %>
                                    <tr data-bs-toggle="modal" data-bs-target="#userDetailModal"
                                        data-userid="<%= user.UserID %>"
                                        data-name="<%= user.First_name %> <%= user.Last_name %>"
                                        data-email="<%= user.Email %>" data-role="<%= user.Role %>"
                                        data-status="<%= statusMap[user.Status].label %>"
                                        data-created-at="<%= user.Created_at %>" onclick="populateModal(this)"
                                        style="cursor: pointer;">
                                        <td>
                                            <%= user.First_name %>
                                                <%= user.Last_name %>
                                        </td>
                                        <td>
                                            <%= user.Email %>
                                        </td>
                                        <td>
                                            <%= user.Role %>
                                        </td>
                                        <td>
                                            <span class="status-badge <%= statusMap[user.Status].class %>">
                                                <%= statusMap[user.Status].label %>
                                            </span>
                                        </td>

                                    </tr>
                                    <% }) %>

                            </tbody>
                        </table>
                    </div>

                    <div class="tab-pane fade" id="regUsersTab">

                        <!-- REGULAR USERS -->
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Email</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(user=> { %>
                                    <% if (user.Role.toLowerCase()==='customer' ) { %>
                                        <tr data-bs-toggle="modal" data-bs-target="#userDetailModal"
                                            data-userid="<%= user.UserID %>"
                                            data-name="<%= user.First_name %> <%= user.Last_name %>"
                                            data-email="<%= user.Email %>" data-role="<%= user.Role %>"
                                            data-status="<%= statusMap[user.Status].label %>"
                                            data-created-at="<%= user.Created_at %>" onclick="populateModal(this)"
                                            style="cursor: pointer;">
                                            <td>
                                                <%= user.First_name %>
                                                    <%= user.Last_name %>
                                            </td>
                                            <td>
                                                <%= user.Email %>
                                            </td>
                                            <td>
                                                <%= user.Role %>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= statusMap[user.Status].class %>">
                                                    <%= statusMap[user.Status].label %>
                                                </span>
                                            </td>

                                        </tr>
                                        <% } %>

                                            <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="tab-pane fade" id="vendorsTab">
                        <!-- VENDORS -->
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Email</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(user=> { %>
                                    <% if (user.Role.toLowerCase()==='vendor' ) { %>
                                        <tr data-bs-toggle="modal" data-bs-target="#userDetailModal"
                                            data-userid="<%= user.UserID %>"
                                            data-name="<%= user.First_name %> <%= user.Last_name %>"
                                            data-email="<%= user.Email %>" data-role="<%= user.Role %>"
                                            data-status="<%= statusMap[user.Status].label %>"
                                            data-created-at="<%= user.Created_at %>" onclick="populateModal(this)"
                                            style="cursor: pointer;">
                                            <td>
                                                <%= user.First_name %>
                                                    <%= user.Last_name %>
                                            </td>
                                            <td>
                                                <%= user.Email %>
                                            </td>
                                            <td>
                                                <%= user.Role %>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= statusMap[user.Status].class %>">
                                                    <%= statusMap[user.Status].label %>
                                                </span>
                                            </td>

                                        </tr>
                                        <% } %>

                                            <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="tab-pane fade" id="driversTab">
                        <!-- DRIVERS TAB -->
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Email</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(user=> { %>
                                    <% if (user.Role.toLowerCase()==='driver' ) { %>
                                        <tr data-bs-toggle="modal" data-bs-target="#userDetailModal"
                                            data-userid="<%= user.UserID %>"
                                            data-name="<%= user.First_name %> <%= user.Last_name %>"
                                            data-email="<%= user.Email %>" data-role="<%= user.Role %>"
                                            data-status="<%= statusMap[user.Status].label %>"
                                            data-created-at="<%= user.Created_at %>" onclick="populateModal(this)"
                                            style="cursor: pointer;">
                                            <td>
                                                <%= user.First_name %>
                                                    <%= user.Last_name %>
                                            </td>
                                            <td>
                                                <%= user.Email %>
                                            </td>
                                            <td>
                                                <%= user.Role %>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= statusMap[user.Status].class %>">
                                                    <%= statusMap[user.Status].label %>
                                                </span>
                                            </td>

                                        </tr>
                                        <% } %>

                                            <% }) %>

                            </tbody>
                        </table>
                    </div>

                    <div class="tab-pane fade" id="adminTab">

                        <!-- ADMIN TAB -->
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Email</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(user=> { %>
                                    <% if (user.Role.toLowerCase()==='admin' ) { %>
                                        <tr data-bs-toggle="modal" data-bs-target="#userDetailModal"
                                            data-userid="<%= user.UserID %>"
                                            data-name="<%= user.First_name %> <%= user.Last_name %>"
                                            data-email="<%= user.Email %>" data-role="<%= user.Role %>"
                                            data-status="<%= statusMap[user.Status].label %>"
                                            data-created-at="<%= user.Created_at %>" onclick="populateModal(this)"
                                            style="cursor: pointer;">
                                            <td>
                                                <%= user.First_name %>
                                                    <%= user.Last_name %>
                                            </td>
                                            <td>
                                                <%= user.Email %>
                                            </td>
                                            <td>
                                                <%= user.Role %>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= statusMap[user.Status].class %>">
                                                    <%= statusMap[user.Status].label %>
                                                </span>
                                            </td>

                                        </tr>
                                        <% } %>

                                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-3">
                    <% if (locals.reason==='self-ban' ) { %>
                        <div class="alert alert-danger">You can't ban your own account! </div>
                        <% } %>

                            <% if (locals.reason==='self-suspend' ) { %>
                                <div class="alert alert-danger">You can't suspend your own account! </div>
                                <% } %>
                </div>

        </div>



    </div>

    <!-- modal that pops up with further user info -->
    <div class="modal fade" id="userDetailModal" tabindex="-1" aria-labelledby="userDetailModal" aria-hidden="true">
        <div class="modal-dialog modal-lg  modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="userInfoModalHeader">User Info</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="userModalBody">
                    <p><strong>Name:</strong> <span data-field="name"></span></p>
                    <p><strong>Email:</strong> <span data-field="email"></span></p>
                    <p><strong>User Type:</strong> <span data-field="role"></span></p>
                    <p><strong>Status:</strong> <span data-field="status"></span></p>
                    <p><strong>Join Date:</strong> <span data-field="created-at"></span></p>
                    <hr>
                    <p><strong>Order Log:</strong> [link to more]</p>
                    <p><strong>Post Log:</strong> [link to more]</p>
                    <p class="m-0"><strong>Prior Issues:</strong> [link to more]</p>

                </div>

                <div class="my-1 mx-3 text-left">
                    <form action="/admins/user-detail" method="GET">
                        <input type="text" name="modalUserID" id="modalUserID" hidden>
                        <button type="submit" class="btn btn-outline-primary">
                            Go to <span id="user-profile-button"></span>'s page
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>

                </div>

                <div class="modal-footer my-2">

                    <div class="d-flex gap-2">
                        <!-- forms for suspending/banning/reinstating -->
                        <form id="reinstateUserForm" method="POST"><button type="submit" class="btn"
                                id="userModalReinstateBtn">Reinstate User</button></form>
                        <form id="suspendUserForm" method="POST"><button type="submit" class="btn"
                                id="userModalSuspendBtn">Suspend</button></form>
                        <form id="banUserForm" method="POST"><button type="submit" class="btn"
                                id="userModalBanBtn">Ban</button></form>
                        
                    </div>
                </div>

            </div>
        </div>
    </div>
    </div>

    <script>
        function setSearchBy(value, label) {
            document.getElementById('searchBy').value = value;
            document.getElementById('searchBtn').textContent = 'Search by ' + label;
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
    <script src="/javascripts/populatePageElements.js"></script>

</body>

</html>