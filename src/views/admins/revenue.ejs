<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Revenue</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

    <div class="main-box">
        <div class="container-fluid table-container">
            <h2 class="ms-2 mt-3 mb-4">Revenue Overview</h2>

            <!-- Summary cards -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <div class="admin-stat-card">
                        <div class="data-stat-icon" style="background:rgba(13,120,59,0.1);color:rgb(22,102,0);">
                            <i class="bi bi-cash-coin"></i>
                        </div>
                        <div>
                            <div class="admin-stat-label">Daily Revenue</div>
                            <div class="admin-stat-value">$<%= totalRevenue.daily.toFixed(2) %></div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="admin-stat-card">
                        <div class="data-stat-icon" style="background:rgba(161,84,229,0.1);color:rgb(48,25,69);">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>
                        <div>
                            <div class="admin-stat-label">Monthly Revenue</div>
                            <div class="admin-stat-value">$<%= totalRevenue.monthly.toFixed(2) %></div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="admin-stat-card">
                        <div class="data-stat-icon" style="background:rgba(13,110,253,0.1);color:rgb(0,60,160);">
                            <i class="bi bi-wallet2"></i>
                        </div>
                        <div>
                            <div class="admin-stat-label">All-Time Revenue</div>
                            <div class="admin-stat-value">$<%= totalRevenue.allTime.toFixed(2) %></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Top merchants -->
            <div class="row g-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white fw-semibold">
                            <i class="bi bi-shop me-2"></i>Top Merchants by Revenue
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Merchant</th>
                                        <th>Orders</th>
                                        <th>Revenue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (topMerchants.length === 0) { %>
                                    <tr><td colspan="3" class="text-center text-muted py-3">No data yet.</td></tr>
                                    <% } %>
                                    <% topMerchants.forEach(m => { %>
                                    <tr>
                                        <td><%= m.MerchantName %></td>
                                        <td><%= m.orderCount %></td>
                                        <td>$<%= m.totalRevenue.toFixed(2) %></td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Recent completed orders -->
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white fw-semibold">
                            <i class="bi bi-receipt me-2"></i>Recent Completed Orders
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Customer</th>
                                        <th>Merchant</th>
                                        <th>Amount</th>
                                        <th style="white-space:nowrap">Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (recentOrders.length === 0) { %>
                                    <tr><td colspan="5" class="text-center text-muted py-3">No completed orders yet.</td></tr>
                                    <% } %>
                                    <% recentOrders.forEach(o => { %>
                                    <tr>
                                        <td><%= o.OrderID %></td>
                                        <td><%= o.First_name %> <%= o.Last_name %></td>
                                        <td><%= o.MerchantName %></td>
                                        <td>$<%= o.TotalAmount.toFixed(2) %></td>
                                        <td style="white-space:nowrap"><%= o.OrderDate ? (isNaN(o.OrderDate) ? o.OrderDate.slice(0,10) : new Date(Number(o.OrderDate)*1000).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'})) : '—' %></td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
</body>
</html>
