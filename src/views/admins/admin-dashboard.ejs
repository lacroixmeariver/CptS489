<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>

<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

    <!-- box for the main area (the entire visible screen aside from navbar basically) -->
    <div class="main-box">

        <!-- container for main dashboard content -->
        <div class="container-fluid table-container">

            <!-- container for all the cards present -->
            <div class="analytics-container">

                <div class="row card-container">
                    <h2 class="ms-2 mt-3 mb-3">Quick View</h2>

                    <!-- cards for some quick reference  -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon"
                                    style="background:rgba(13, 120, 59, 0.1);color:rgb(22, 102, 0);">
                                    <i class="bi bi bi-cash-coin"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">Daily revenue</div>
                                    <div class="admin-stat-value">Total revenue for the last 24 hours</div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon"
                                    style="background:rgba(161, 84, 229, 0.1);color:rgb(48, 25, 69);">
                                    <i class="bi bi-graph-up-arrow"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">Monthly revenue</div>
                                    <div class="admin-stat-value">Total revenue for the last 30 days</div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon"
                                    style="background:rgba(236, 93, 49, 0.1);color:rgb(185, 31, 17);">
                                    <i class="bi bi-person-plus-fill"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-num">
                                        <%= userSum %>
                                    </div>
                                    <div class="admin-stat-value">New users registered in last 30 days</div>

                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon"
                                    style="background:rgba(157, 236, 221, 0.1);color:rgb(10, 146, 146);">
                                    <i class="bi bi-bag-check"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">Daily orders</div>
                                    <div class="admin-stat-value">All orders gone out today</div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="m-3">


                    </div>
                </div>

            </div>
            <div class="container">
                <!-- tab nav -->
                <ul class="nav nav-tabs" id="dashboardActivityTabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#newUsersTab">New Users</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#vendorAppsTab">Vendor Applications</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#recentOrdersTab">Recent Orders</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#recentMessagesTab">Messages</a>
                    </li>
                </ul>

                <div class="tab-content container-fluid">

                    <% const statusMap={ 0: {label: 'Active' , class: 'status-active' }, 1: {label: 'Banned' ,
                        class: 'status-banned' }, 2: {label: 'Suspended' , class: 'status-suspended' } } %>



                        <div class="tab-pane show active fade m-1" id="newUsersTab">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Merchant ID</th>
                                        <th>Merchant Name</th>
                                        <th>Address</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% newUsers.slice(0, 10).forEach(user=>{ %>
                                        <tr data-bs-toggle="modal" data-bs-target="#userDetailModal"
                                            data-userid="<%= user.UserID %>"
                                            data-name="<%= user.First_name %> <%= user.Last_name %>"
                                            data-email="<%= user.Email %>" data-role="<%= user.Role %>"
                                            data-status="<%= statusMap[user.Status].label %>"
                                            data-created-at="<%= user.Created_at %>" onclick="populateModal(this)"
                                            style="cursor: pointer;">
                                            <td>
                                                <%= user.UserID %>
                                            </td>
                                            <td>
                                                <%= user.First_name %>
                                                    <%= user.Last_name %>
                                            </td>
                                            <td>
                                                <%= user.Email %>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= statusMap[user.Status].class %>">
                                                    <%= statusMap[user.Status].label %>
                                                </span>
                                            </td>

                                        </tr>
                                        <% }) %>
                                </tbody>

                            </table>
                            <a href="/admins/manage-users">
                                <button class="btn btn-primary">
                                    View all users
                                </button>
                            </a>

                        </div>

                        <!-- MESSAGES TAB -->
                        <div class="tab-pane fade" id="recentMessagesTab">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>From</th>
                                        <th>Subject</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>

                                </tbody>
                            </table>
                            <a href="/admins/issues">
                                <button class="btn btn-primary">
                                    View all issues
                                </button>
                            </a>
                        </div>

                        <div class="tab-pane fade" id="recentOrdersTab">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Customer</th>
                                        <th>Total</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <span class="status-badge">
                                        </span>
                                    </td>
                                </tbody>
                            </table>
                            <a href="/admins/orders">
                                <button class="btn btn-primary">
                                    View all recent orders
                                </button>
                            </a>
                        </div>

                        <div class="tab-pane fade" id="vendorAppsTab">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>User ID</th>
                                        <th>User Name</th>
                                        <th>Email</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>

                                </tbody>

                            </table>

                            <a href="/admins/vendor-applications">
                                <button class="btn btn-primary">
                                    View all applications
                                </button>
                            </a>

                        </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/javascripts/common-elements.js"></script>
</body>

</html>