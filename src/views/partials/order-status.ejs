

<% if (orders.length === 0) { %>
    <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
        <i class="bi bi-bag" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
        <div>No active orders right now.</div>
        <a href="/browse" style="color:var(--burnt-orange-primary);font-size:0.88rem;">Browse cooks →</a>
    </div>
<% } else { %>
    <% orders.forEach(order => { %>
    <div style="background:#fff;border-radius:12px;padding:18px 22px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,.06);">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
            <span style="font-family:'Poppins',sans-serif;font-weight:600;">Order #<%= order.OrderID %></span>
            <span style="font-size:0.8rem;padding:3px 10px;border-radius:20px;background:rgba(197,90,58,.1);color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;">
                <%= order.OrderStatus %>
            </span>
        </div>
        <div style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:#666;">
            <span><i class="bi bi-shop me-1"></i><%= order.MerchantName %></span>
            &nbsp;·&nbsp;
            <span><i class="bi bi-clock me-1"></i><%= order.TimeOrdered %></span>
            &nbsp;·&nbsp;
            <strong>$<%= order.TotalAmount.toFixed(2) %></strong>
        </div>
    </div>
    <% }) %>
<% } %>