<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — My Dashboard</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- App styles -->
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="merchant-dashboard.css">
    <link rel="stylesheet" href="/stylesheets/customer-dashboard.css">
</head>
<body>

<!-- ── Navigation Bar ────────────────────────────── -->
<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="../src/index.html" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">
        HomePlate
    </a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, User
        </span>
        <a href="/" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">
            Log Out
        </a>
    </div>
</nav>

<!-- ── Dashboard Body ────────────────────────────── -->
<div class="dashboard-layout">

    <!-- Sidebar -->
    <div class="sidebar-container" style="display:flex;flex-direction:column;">
        <nav class="sidebar-nav">
            <a href="index.html" class="sidebar-nav-link" id="sidebar-home">
                <i class="bi bi-house-fill"></i>
                <span>Home</span>
            </a>
            <a href="browse.html" class="sidebar-nav-link" id="sidebar-browse">
                <i class="bi bi-search"></i>
                <span>Browse</span>
            </a>
        </nav>
        <!-- Profile avatar pushed to bottom -->
        <div style="margin-top:auto;padding-bottom:12px;">
            <a href="profile.html" class="sidebar-nav-link" id="sidebar-profile">
                <i class="bi bi-person-circle"></i>
                <span>Profile</span>
            </a>
        </div>
    </div>

    <!-- Main content -->
    <main class="main-content">

        <!-- Page title -->
        <div class="mb-4">
            <h1 style="font-family:'Poppins',sans-serif;font-size:1.6rem;font-weight:700;color:var(--charcoal-gray-secondary);margin:0;">
                My Dashboard
            </h1>
            <p style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:#888;margin:4px 0 0;">
                Track your orders, browse history, and manage your reviews.
            </p>
        </div>

        <!-- Stat cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="cust-stat-card" style="border-left:4px solid var(--burnt-orange-primary);">
                    <div class="cust-stat-icon" style="background:rgba(197,90,58,.10);color:var(--burnt-orange-primary);">
                        <i class="bi bi-bag-check"></i>
                    </div>
                    <div>
                        <div class="stat-num">1</div>
                        <div class="stat-label">Active Order</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="cust-stat-card" style="border-left:4px solid var(--sage-green-secondary);">
                    <div class="cust-stat-icon" style="background:rgba(122,155,110,.10);color:var(--sage-green-secondary);">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <div>
                        <div class="stat-num">12</div>
                        <div class="stat-label">Total Orders</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="cust-stat-card" style="border-left:4px solid var(--golden-yellow-secondary);">
                    <div class="cust-stat-icon" style="background:rgba(232,180,74,.10);color:var(--golden-yellow-secondary);">
                        <i class="bi bi-star"></i>
                    </div>
                    <div>
                        <div class="stat-num">3</div>
                        <div class="stat-label">Reviews Written</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="cust-stat-card" style="border-left:4px solid #e06b6b;">
                    <div class="cust-stat-icon" style="background:rgba(224,107,107,.10);color:#e06b6b;">
                        <i class="bi bi-heart"></i>
                    </div>
                    <div>
                        <div class="stat-num">5</div>
                        <div class="stat-label">Saved Cooks</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section tab nav -->
        <nav class="section-tab-nav mb-4">
            <a href="#" class="tab-btn active" id="tab-order-status"
               onclick="showSection('order-status'); return false;">
                <i class="bi bi-bag-check me-1"></i>Current Order
            </a>
            <a href="#" class="tab-btn" id="tab-history"
               onclick="showSection('history'); return false;">
                <i class="bi bi-receipt me-1"></i>Order History
            </a>
            <a href="#" class="tab-btn" id="tab-reviews"
               onclick="showSection('reviews'); return false;">
                <i class="bi bi-star me-1"></i>Reviews
            </a>
        </nav>

        <!-- Dynamic section content -->
        <div id="section-content">
            <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                <div class="spinner-border" style="color:var(--burnt-orange-primary);" role="status"></div>
                <div class="mt-2" style="font-size:0.88rem;">Loading…</div>
            </div>
        </div>

    </main>
</div><!-- /dashboard-layout -->

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
const sectionFiles = {
    'order-status': 'customer-order-status.html',
    'history':      'customer-order-history.html',
    'reviews':      'customer-reviews.html'
};

function clearSection() {
    document.getElementById('section-content').innerHTML =
        '<div class="text-center py-5" style="color:#bbb;font-family:\'Poppins\',sans-serif;">' +
        '<div class="spinner-border" style="color:var(--burnt-orange-primary);" role="status"></div>' +
        '<div class="mt-2" style="font-size:0.88rem;">Loading…</div></div>';
}

function setActiveTab(section) {
    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.sidebar-nav-link').forEach(el => el.classList.remove('active'));
    const tab = document.getElementById('tab-' + section);
    if (tab) tab.classList.add('active');
}

function showSection(section) {
    setActiveTab(section);
    clearSection();
    const file = sectionFiles[section];
    if (!file) return;
    fetch(file)
        .then(r => {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.text();
        })
        .then(html => {
            const container = document.getElementById('section-content');
            container.innerHTML = html;
            // Execute any <script> tags injected with innerHTML
            container.querySelectorAll('script').forEach(oldScript => {
                const newScript = document.createElement('script');
                newScript.textContent = oldScript.textContent;
                oldScript.parentNode.replaceChild(newScript, oldScript);
            });
        })
        .catch(err => {
            document.getElementById('section-content').innerHTML =
                '<div class="alert alert-danger">Could not load section: ' + err.message + '</div>';
        });
}

document.addEventListener('DOMContentLoaded', () => showSection('order-status'));
</script>

</body>
</html>
