<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — <%= merchant.MerchantName %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body data-role="<%= user.Role %>" data-user="<%= user.first_name %>">

<div class="main-box">
<!-- ── Back breadcrumb ────────────────────────── -->
<div style="background:var(--cream-primary);padding:10px 32px;border-bottom:1px solid #eadfc8;">
    <a href="/customer/browse" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;">
        <i class="bi bi-arrow-left me-1"></i>Back to Browse
    </a>
</div>

<!-- ── Restaurant Profile Banner ─────────────── -->
<div class="restaurant-profile-banner">
    <div style="max-width:1200px;margin:0 auto;">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <!-- Cook avatar -->
            <div style="width:80px;height:80px;border-radius:16px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-weight:700;font-size:2.2rem;color:#fff;flex-shrink:0;">
                <%= merchant.name.charAt(0) %>
            </div>
            <!-- Info -->
            <div class="flex-grow-1">
                <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.5rem;color:#fff;margin:0 0 4px;">
                    <%= merchant.name %>
                </h1>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:rgba(255,255,255,.8);margin-bottom:10px;">
                    Home-cooked meals by <%= merchant.name %>
                </div>
                <div class="d-flex flex-wrap gap-3" style="font-family:'Open Sans',sans-serif;font-size:0.83rem;color:rgba(255,255,255,.85);">
                    <span><i class="bi bi-star-fill me-1" style="color:var(--golden-yellow-secondary);"></i><%= merchant.storeScore %> (<%= reviews.length %>)</span>
                </div>
            </div>
        </div>

        <!-- Bio -->
        <% if (merchant.bio) { %>
        <p style="font-family:'Open Sans',sans-serif;font-size:0.86rem;color:rgba(255,255,255,.75);margin:16px 0 0;max-width:700px;line-height:1.6;">
            <%= merchant.bio %>
        </p>
        <% } %>
    </div>
</div>

<!-- ── Main Content ──────────────────────────── -->
<div style="max-width:1200px;margin:0 auto;padding:28px 24px;">
    <div class="row g-4">

        <!-- ── Menu Column ─────────────────────── -->
        <div class="col-lg-8">
        <% if (menuItems.length === 0) { %>
            <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                <i class="bi bi-card-list" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
                <div>Menu is being prepared. Check back soon!</div>
            </div>
        <% } else { %>
            <% menuItems.forEach(item => { %>
                <div class="menu-item-card">
                    <div class="menu-item-img" style="background:#f5ede0;"></div>
                    <div class="menu-item-info">
                        <div class="menu-item-name"><%= item.name %></div>
                        <div class="menu-item-desc"><%= item.description %></div>
                        <div class="menu-item-price">$<%= item.price.toFixed(2) %></div>
                    </div>
                    <button class="menu-item-add" onclick="addToCart('<%= item.itemId %>', '<%= item.name %>', <%= item.price %>)">
                        <i class="bi bi-plus me-1"></i>Add
                    </button>
                </div>
            <% }); %>
        <% } %>
    </div>

    <div class="d-flex align-items-center justify-content-between mt-4 mb-2">
        <h3 style="font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 1.25rem; margin: 0;">Reviews</h3>
        <button class="btn btn-hp btn-sm" data-bs-toggle="modal" data-bs-target="#reviewModal">
            <i class="bi bi-star me-1"></i>Write a Review
        </button>
    </div>
    <% if (reviews.length === 0) { %>
        <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
            <i class="bi bi-star" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
            <div>No reviews yet. Be the first to review <%= merchant.name %>!</div>
        </div>
    <% } else { %>
        <% reviews.forEach(review => { %>
            <div class="review-card">
                <div class="review-header">
                    <span class="review-rating">⭐ <%= review.Rating %></span>
                    <span class="reviewer-name"><%= review.CustomerName %></span>
                    <span class="review-date"><%= review.ReviewDate %></span>
                </div>
                <div class="review-content">
                    <p><%= review.Comment %></p>
                </div>
            </div>
        <% }); %>
    <% } %>


        <!-- ── Cart Widget Sidebar ──────────────── -->
        <div class="col-lg-4">
            <div class="cart-widget">
                <div class="cart-widget-title">
                    <i class="bi bi-bag me-1"></i>Your Order
                </div>

                <!-- Empty state -->
                <div id="cart-empty" style="text-align:center;padding:20px 0;color:#bbb;">
                    <i class="bi bi-bag" style="font-size:32px;display:block;margin-bottom:8px;"></i>
                    <div style="font-family:'Open Sans',sans-serif;font-size:0.85rem;">Your cart is empty.</div>
                    <div style="font-family:'Open Sans',sans-serif;font-size:0.8rem;margin-top:4px;">Add items from the menu to get started.</div>
                </div>

                <!-- Cart items (shown after adding) -->
                <div id="cart-items" style="display:none;"></div>

                <!-- Toggle demo button -->
                <button class="btn btn-hp-outline w-100 mt-3" style="font-size:0.82rem;" onclick="toggleCart()">
                    <i class="bi bi-eye me-1"></i>
                </button>
                <a href="/customer/checkout" class="btn btn-hp w-100 mt-3" style="font-size:0.9rem;">
                    <i class="bi bi-credit-card me-1"></i>Checkout
                </a>
            </div>

        </div><!-- /cart sidebar -->
    </div><!-- /row -->
</div><!-- /main content -->

<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header" style="border-bottom:1px solid #f0e8d8;">
                <h5 class="modal-title" id="reviewModalLabel" style="font-family:'Poppins',sans-serif;font-weight:600;">
                    Review <%= merchant.name %>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="review-form">
            <div class="modal-body" style="padding:24px;">
                <div class="mb-3">
                    <label style="font-family:'Poppins',sans-serif;font-weight:500;font-size:0.9rem;margin-bottom:8px;display:block;">Rating</label>
                    <div id="star-row" style="display:flex;gap:6px;font-size:1.8rem;cursor:pointer;">
                        <% for (let s = 1; s <= 5; s++) { %>
                        <span class="star" data-val="<%= s %>" style="color:#ddd;">&#9733;</span>
                        <% } %>
                    </div>
                    <input type="hidden" id="rating-input" name="rating" value="0">
                </div>
                <div class="mb-1">
                    <label for="review-comment" style="font-family:'Poppins',sans-serif;font-weight:500;font-size:0.9rem;margin-bottom:6px;display:block;">Comment <span style="color:#aaa;font-weight:400;">(optional)</span></label>
                    <textarea id="review-comment" name="comment" rows="3" class="form-control" placeholder="Share your experience…" style="border-radius:10px;resize:none;"></textarea>
                </div>
                <div id="review-error" style="color:#e06b6b;font-size:0.82rem;margin-top:8px;display:none;">Please select a star rating.</div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f0e8d8;">
                <button type="button" class="btn btn-hp-outline" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-hp">Submit Review</button>
            </div>
            </form>
        </div>
    </div>
</div>

</div><!-- /main-box -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
let cart = loadCart();

function loadCart()
{
    const saved = localStorage.getItem("cart");
    return saved ? JSON.parse(saved) : {
        merchantId: <%= merchant.merchantId %>,
        merchantName: "<%= merchant.name %>",
        items: []
    };
}

function saveCart() {
    localStorage.setItem("cart", JSON.stringify(cart));
}

function addToCart(id, name, price) {
    if (cart.merchantId !== <%= merchant.merchantId %>) {
        cart = {
            merchantId: <%= merchant.merchantId %>,
            merchantName: "<%= merchant.name %>",
            items: []
        };
    }   

    const existing = cart.items.find(i => i.itemId === id);
    if (existing) {
        existing.quantity++;
    } else {
        cart.items.push({ 
            itemId: id, 
            name, 
            price: Number(price), 
            quantity: 1 
        });
    }

        saveCart();
        renderCart();

}

function removeFromCart(id) {
    cart.items = cart.items.filter(i => i.itemId !== id);
    saveCart();
    renderCart();
}

function renderCart() {
    const empty = document.getElementById('cart-empty');
    const items = document.getElementById('cart-items');

    if (cart.items.length === 0) {
        empty.style.display = 'block';
        items.style.display = 'none';
        items.innerHTML = '';
        return;
    }

    empty.style.display = 'none';
    items.style.display = 'block';

    items.innerHTML = cart.items.map(item => `
        <div class="cart-item-row">
            <span class="cart-qty-btn" onclick="decreaseQty('${item.itemId}')">-</span>
            <span class="cart-item-name">${item.name} x${item.quantity}</span>
            <span class="cart-qty-btn" onclick="increaseQty('${item.itemId}')">+</span>
            <span class="cart-item-price">$${(item.price * item.quantity).toFixed(2)}</span>
            <span class="cart-remove-btn" onclick="removeFromCart('${item.itemId}')"><i class="bi bi-x"></i></span>
        </div>
    `).join('');
}

function increaseQty(id) {
    const item = cart.items.find(i => i.itemId === id);
    if (item) {
        item.quantity++;
        saveCart();
        renderCart();
    }
}

function decreaseQty(id) {
    const item = cart.items.find(i => i.itemId === id);
    if (item && item.quantity > 1) {
        item.quantity--;
    } else {
        removeFromCart(id);
        return;
    }

    saveCart();
    renderCart();
}

function toggleCart() {
    const empty = document.getElementById('cart-empty');
    const items = document.getElementById('cart-items');

    if (items.style.display === 'none') {
        empty.style.display = cart.items.length === 0 ? 'block' : 'none';
        items.style.display = cart.items.length === 0 ? 'none' : 'block';
    } else {
        empty.style.display = 'block';
        items.style.display = 'none';
    }
}

renderCart();
</script>

<script>

const stars = document.querySelectorAll('#star-row .star');
let selectedRating = 0;

stars.forEach(star => {
    star.addEventListener('mouseover', () => {
        stars.forEach(s => s.style.color = s.dataset.val <= star.dataset.val ? 'var(--golden-yellow-secondary)' : '#ddd');
    });
    star.addEventListener('mouseout', () => {
        stars.forEach(s => s.style.color = s.dataset.val <= selectedRating ? 'var(--golden-yellow-secondary)' : '#ddd');
    });
    star.addEventListener('click', () => {
        selectedRating = parseInt(star.dataset.val);
        document.getElementById('rating-input').value = selectedRating;
        stars.forEach(s => s.style.color = s.dataset.val <= selectedRating ? 'var(--golden-yellow-secondary)' : '#ddd');
        document.getElementById('review-error').style.display = 'none';
    });
});


document.getElementById('reviewModal').addEventListener('hidden.bs.modal', () => {
    selectedRating = 0;
    document.getElementById('rating-input').value = 0;
    document.getElementById('review-comment').value = '';
    stars.forEach(s => s.style.color = '#ddd');
    document.getElementById('review-error').style.display = 'none';
});

// Submit
document.getElementById('review-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (selectedRating === 0) {
        document.getElementById('review-error').style.display = 'block';
        return;
    }
    const comment = document.getElementById('review-comment').value.trim();
    const res = await fetch('/customer/merchant/<%= merchant.merchantId %>/review', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rating: selectedRating, comment })
    });
    if (res.ok) {
        bootstrap.Modal.getInstance(document.getElementById('reviewModal')).hide();
        window.location.reload();
    }
});
</script>
<script src="/javascripts/common-elements.js"></script>
</body>
</html>
