<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Reset Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../style.css">
    <style>
        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
            background-color: var(--cream-primary);
        }
        .auth-card {
            background: #fff;
            border-radius: 16px;
            padding: 40px 44px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.09);
        }
        .auth-logo {
            font-family: 'Pacifico', cursive;
            color: var(--burnt-orange-primary);
            font-size: 2rem;
            text-align: center;
            display: block;
            margin-bottom: 6px;
            text-decoration: none;
        }
        .auth-tagline {
            font-family: 'Open Sans', sans-serif;
            font-size: 0.88rem;
            color: #aaa;
            text-align: center;
            margin-bottom: 28px;
        }
        .auth-title {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--charcoal-gray-secondary);
            margin-bottom: 10px;
        }
        .auth-subtitle {
            font-family: 'Open Sans', sans-serif;
            font-size: 0.88rem;
            color: #888;
            margin-bottom: 24px;
            line-height: 1.55;
        }
        .auth-label {
            font-family: 'Poppins', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--charcoal-gray-secondary);
        }
        .auth-input {
            font-family: 'Open Sans', sans-serif;
            font-size: 0.9rem;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            padding: 10px 14px;
            background: #fafafa;
            transition: border-color .2s;
        }
        .auth-input:focus {
            border-color: var(--burnt-orange-primary);
            box-shadow: 0 0 0 3px rgba(197,90,58,.12);
            outline: none;
            background: #fff;
        }
        .btn-auth {
            background: var(--burnt-orange-primary);
            color: #fff;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
            border: none;
            border-radius: 8px;
            padding: 11px;
            width: 100%;
            transition: background .2s;
        }
        .btn-auth:hover { background: #b04e31; color: #fff; }
        .btn-auth:disabled { background: #e0a070; cursor: not-allowed; }
        .auth-footer {
            text-align: center;
            font-family: 'Open Sans', sans-serif;
            font-size: 0.86rem;
            color: #888;
            margin-top: 22px;
        }
        .auth-footer a {
            color: var(--burnt-orange-primary);
            font-weight: 600;
            text-decoration: none;
        }
        .auth-footer a:hover { text-decoration: underline; }

        /* Success confirmation panel */
        .success-panel {
            display: none;
            text-align: center;
        }
        .success-icon-ring {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(122,155,110,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 32px;
            color: var(--sage-green-secondary);
        }
        .success-heading {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--charcoal-gray-secondary);
            margin-bottom: 10px;
        }
        .success-body {
            font-family: 'Open Sans', sans-serif;
            font-size: 0.88rem;
            color: #888;
            line-height: 1.6;
            margin-bottom: 28px;
        }
        .success-body strong {
            font-family: 'Poppins', sans-serif;
            color: var(--charcoal-gray-secondary);
            font-weight: 600;
        }
        .btn-auth-outline {
            background: transparent;
            color: var(--burnt-orange-primary);
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
            border: 1.5px solid var(--burnt-orange-primary);
            border-radius: 8px;
            padding: 10px;
            width: 100%;
            transition: all .2s;
            text-decoration: none;
            display: block;
            text-align: center;
        }
        .btn-auth-outline:hover {
            background: var(--burnt-orange-primary);
            color: #fff;
        }
        .resend-row {
            font-family: 'Open Sans', sans-serif;
            font-size: 0.83rem;
            color: #aaa;
            text-align: center;
            margin-top: 14px;
        }
        .resend-row a {
            color: var(--burnt-orange-primary);
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }
        .resend-row a:hover { text-decoration: underline; }
    </style>
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-card">

        <!-- Brand -->
        <a href="index.html" class="auth-logo">HomePlate</a>
        <div class="auth-tagline">Homemade meals from cooks in your neighborhood</div>

        <!-- ── Request form ── -->
        <div id="reset-form-panel">
            <div class="auth-title">Reset your password</div>
            <div class="auth-subtitle">
                Enter the email address linked to your account and we'll send you a link to reset your password.
            </div>

            <form id="reset-form" onsubmit="return submitReset(event)">

                <div class="mb-4">
                    <label class="auth-label mb-1" for="reset-email">Email address</label>
                    <input type="email" id="reset-email" class="form-control auth-input"
                        placeholder="you@example.com" required autocomplete="email">
                    <div id="reset-error" class="mt-2" style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#dc3545;display:none;">
                        Please enter a valid email address.
                    </div>
                </div>

                <button type="submit" class="btn-auth" id="reset-btn">
                    <i class="bi bi-envelope me-2"></i>Send Reset Link
                </button>
            </form>
        </div>

        <!-- ── Success confirmation (shown after submit) ── -->
        <div class="success-panel" id="success-panel">
            <div class="success-icon-ring">
                <i class="bi bi-envelope-check-fill"></i>
            </div>
            <div class="success-heading">Check your inbox</div>
            <div class="success-body">
                We've sent a password reset link to<br>
                <strong id="sent-email-display"></strong><br><br>
                The link will expire in 30 minutes. If you don't see it, check your spam folder.
            </div>
            <a href="login.html" class="btn-auth-outline">
                <i class="bi bi-arrow-left me-2"></i>Back to Log In
            </a>
            <div class="resend-row">
                Didn't receive it? <a onclick="resendLink()">Resend email</a>
            </div>
        </div>

        <div class="auth-footer" id="back-to-login-footer">
            Remember your password? <a href="login.html">Log in</a>
        </div>

    </div>
</div>

<script>
function submitReset(e) {
    e.preventDefault();
    const emailEl = document.getElementById('reset-email');
    const errEl   = document.getElementById('reset-error');
    const email   = emailEl.value.trim();

    errEl.style.display = 'none';

    if (!email) {
        errEl.style.display = 'block';
        return false;
    }

    // Mock: disable button briefly to simulate sending
    const btn = document.getElementById('reset-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Sending…';

    setTimeout(() => {
        document.getElementById('sent-email-display').textContent = email;
        document.getElementById('reset-form-panel').style.display = 'none';
        document.getElementById('back-to-login-footer').style.display = 'none';
        document.getElementById('success-panel').style.display = 'block';
    }, 1200);

    return false;
}

function resendLink() {
    const emailEl = document.getElementById('sent-email-display');
    const resendEl = document.querySelector('.resend-row');
    resendEl.innerHTML = '<i class="bi bi-check-circle-fill me-1" style="color:var(--sage-green-secondary);"></i>'
        + '<span style="color:var(--sage-green-secondary);font-family:\'Open Sans\',sans-serif;font-size:0.83rem;">Reset link resent!</span>';
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
