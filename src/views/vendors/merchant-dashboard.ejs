<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Merchant Dashboard</title>
    <!-- these are preconnects + google fonts link they're for the custom fonts  -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    
    <!-- bootstrap and CSS style sheet links -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">

    <!-- box for the main area (the entire visible screen aside from navbar basically) -->
    <div class="main-box">

        <!-- container for main dashboard content -->
        <div class="dashboard-container">

            <!-- container for all the cards present -->
            <div class="analytics-container">

                <% if (verifyMsg) { %>
                <% const vmColor = verifyMsg==='Rejected' ? '#fee2e2' : '#fef9c3'; const vmText = verifyMsg==='Rejected' ? '#991b1b' : '#78350f'; %>
                <div style="background:<%= vmColor %>;color:<%= vmText %>;border-radius:10px;padding:12px 18px;margin-bottom:16px;font-family:'Open Sans',sans-serif;font-size:0.9rem;display:flex;align-items:center;gap:10px;">
                    <i class="bi bi-<%= verifyMsg==='Rejected' ? 'x-circle-fill' : 'hourglass-split' %>" style="font-size:1.2rem;"></i>
                    <span>Your store cannot open yet — Verification status: <strong><%= verifyMsg %></strong>. Please wait for admin approval.</span>
                </div>
                <% } %>
                <% if (noMenuMsg) { %>
                <div style="background:#fef9c3;color:#78350f;border-radius:10px;padding:12px 18px;margin-bottom:16px;font-family:'Open Sans',sans-serif;font-size:0.9rem;display:flex;align-items:center;gap:10px;">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size:1.2rem;"></i>
                    <span>You need at least one menu item before you can open your store. <a href="/vendor/my-menu" style="color:#92400e;font-weight:600;">Add items to your menu</a>.</span>
                </div>
                <% } %>

                <div class="row card-container">
                    <h2 id="recent-activity-heading">What to do next</h2>
                    <div class="card"> 
                        <a href="/vendor/open-store">
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="height:100px;background:var(--sage-green-secondary);">
                                <i class="bi bi-house-fill" style="font-size:2.5rem;color:#fff;"></i>
                            </div>
                            <div class="card-body">
                                <p class="card-text">Open Store</p>
                            </div>
                        </a>
                    </div>

                    <div class="card"> 
                        <a href="/vendor/my-menu">
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="height:100px;background:var(--sage-green-secondary);">
                                <i class="bi bi-journal-text" style="font-size:2.5rem;color:#fff;"></i>
                            </div>
                            <div class="card-body">
                                <p class="card-text">My Menu</p>
                            </div>
                        </a>
                    </div>
                   <div class="card"> 
                        <a href="/vendor/reports">
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="height:100px;background:var(--sage-green-secondary);">
                                <i class="bi bi-bar-chart-fill" style="font-size:2.5rem;color:#fff;"></i>
                            </div>
                            <div class="card-body">
                                <p class="card-text">Reports</p>
                            </div>
                        </a>
                    </div>

                    <div class="card">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#reviewsModal">
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="height:100px;background:var(--sage-green-secondary);">
                                <i class="bi bi-star-fill" style="font-size:2.5rem;color:#fff;"></i>
                            </div>
                            <div class="card-body">
                                <p class="card-text">My Reviews</p>
                            </div>
                        </a>
                    </div>

                    <div class="card">
                        <a href="/vendor/profile">
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="height:100px;background:var(--sage-green-secondary);">
                                <i class="bi bi-person-circle" style="font-size:2.5rem;color:#fff;"></i>
                            </div>
                            <div class="card-body">
                                <p class="card-text">My Profile</p>
                            </div>
                        </a>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>

<div class="modal fade" id="reviewsModal" tabindex="-1" aria-labelledby="reviewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header">
                <h5 class="modal-title" id="reviewsModalLabel" style="font-family:'Poppins',sans-serif;font-weight:600;">
                    <i class="bi bi-star-fill me-2" style="color:var(--golden-yellow-secondary);"></i>My Reviews
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="reviews-modal-body" style="padding:24px;max-height:60vh;overflow-y:auto;">
                <div class="text-center py-4" style="color:#bbb;">
                    <div class="spinner-border spinner-border-sm me-2"></div> Loading…
                </div>
            </div>
        </div>
    </div>
</div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.getElementById('reviewsModal').addEventListener('show.bs.modal', () => {
    const body = document.getElementById('reviews-modal-body');
    body.innerHTML = '<div class="text-center py-4" style="color:#bbb;"><div class="spinner-border spinner-border-sm me-2"></div> Loading…</div>';
    fetch('/vendor/reviews')
        .then(r => r.json())
        .then(reviews => {
            if (reviews.length === 0) {
                body.innerHTML = '<div class="text-center py-4" style="color:#bbb;font-family:\'Poppins\',sans-serif;"><i class="bi bi-star" style="font-size:2rem;display:block;margin-bottom:8px;"></i>No reviews yet.</div>';
                return;
            }
            body.innerHTML = reviews.map(r => `
                <div style="background:var(--sage-green-secondary);border-radius:12px;padding:14px 18px;margin-bottom:10px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                        <span style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.9rem;">${r.CustomerName}</span>
                        <span style="font-size:0.82rem;color:#888;">${r.ReviewDate}</span>
                    </div>
                    <div style="margin-bottom:6px;">⭐ ${r.Rating}</div>
                    <div style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:#555;">${r.Comment || '<em style="color:#bbb;">No comment</em>'}</div>
                </div>
            `).join('');
        })
        .catch(() => {
            body.innerHTML = '<div class="alert alert-danger">Could not load reviews.</div>';
        });
});
</script>
<script src="/javascripts/common-elements.js"></script>
</body>
</html>
