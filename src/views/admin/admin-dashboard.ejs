<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>
<body data-role="<%= user.Role %>" data-user="<%= user.first_name %>">
    
    <!-- box for the main area (the entire visible screen aside from navbar basically) -->
    <div class="main-box">

        <!-- container for main dashboard content -->
        <div class="container-fluid table-container">

            <!-- container for all the cards present -->
            <div class="analytics-container">

                <div class="row card-container">
                    <h2 class="ms-2 mt-3 mb-3">Quick View</h2>
                    
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon" style="background:rgba(13, 120, 59, 0.1);color:rgb(22, 102, 0);">
                                    <i class="bi bi bi-cash-coin"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">Daily revenue</div>
                                    <div class="admin-stat-value">Total revenue for the last 24 hours</div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon" style="background:rgba(161, 84, 229, 0.1);color:rgb(48, 25, 69);">
                                    <i class="bi bi-graph-up-arrow"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">Monthly revenue</div>
                                    <div class="admin-stat-value">Total revenue for the last 30 days</div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon" style="background:rgba(236, 93, 49, 0.1);color:rgb(185, 31, 17);">
                                    <i class="bi bi-person-plus-fill"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">New users</div>
                                    <div class="admin-stat-value">New users registered in last 30 days</div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="#" style="text-decoration: none;">
                            <div class="admin-stat-card">
                                <div class="data-stat-icon" style="background:rgba(157, 236, 221, 0.1);color:rgb(10, 146, 146);">
                                    <i class="bi bi-bag-check"></i>
                                </div>
                                <div>
                                    <div class="admin-stat-label">Daily orders</div>
                                    <div class="admin-stat-value">All orders gone out today</div>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>                
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script src="/javascripts/common-elements.js"></script>
</body>
</html>