        </div>

        <!-- modal that pops up with further user info -->
        <div class="modal fade" id="disputeModal" tabindex="-1" aria-labelledby="disputeModal" aria-hidden="true">
            <div class="modal-dialog modal-lg  modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="disputeInfoModal">Dispute Info</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="disputesModalBody">
                        <p><strong>Customer:</strong> [info]</p>
                        <p><strong>Vendor:</strong> [info]</p>
                        <hr>
                        <p><strong>Order ID:</strong> [info]</p>
                        <p><strong>Date:</strong> [info]</p>
                        <p><strong>Total:</strong> [info]</p>
                        <p><strong>Status:</strong> [info]</p>
                        <hr>
                        <p class="m-0"><strong>Dispute Description:</strong> [info]</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn" id="orderModalResolveBtn">Mark as Resolved</button>
                        <button type="button" class="btn" id="orderModalMoreInfoBtn">Request Info</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
</body>
</html>
