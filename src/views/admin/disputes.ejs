                                <th scope="col">Date/Time Posted</th>
                                <th scope="col">Total</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody data-bs-toggle="modal" data-bs-target="#disputeModal">
                            <tr>
                                <td>#000000</td>
                                <td>[username]</td>
                                <td>[vendor]</td>
                                <td>MM/DD/YYYY HH:MM:SS</td>
                                <td>$00.00</td>
                                <td><span class="status-badge">Status</span></td>
                            </tr>
                            <tr>
                                <td>#000000</td>
