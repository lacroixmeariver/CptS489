                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#resolvedDisputes">Resolved</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#appealedDisputes">Appeals</a>
                </li>
                <li class="nav-item"> 
                    <a href="#allDisputes" class="nav-link" data-bs-toggle="tab" aria-current="page">All Issues</a>
                </li>
                
            </ul>

