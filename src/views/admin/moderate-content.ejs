                                <td>1</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="resolvedIssues">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">Issue ID</th>
                                <th scope="col">Item/Review ID</th>
