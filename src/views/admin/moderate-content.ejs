                                <td>1</td>
                            </tr>
                            <tr>
                                <td>#111111</td>
                                <td>[type]0000</td>
                                <td>MM/DD/YYYY HH:MM:SS</td>
                                <td>1</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="appealedIssues">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">Issue ID</th>
                                <th scope="col">Item/Review ID</th>
                                <th scope="col">Date/Time Posted</th>
                                <th scope="col">Flag Count</th>
                            </tr>
                        </thead>
                        <tbody data-bs-toggle="modal" data-bs-target="#issuesModal">
                            <tr>
                                <td>#111111</td>
                                <td>[type]0000</td>
                                <td>MM/DD/YYYY HH:MM:SS</td>
                                <td>1</td>
                            </tr>
                            <tr>
                                <td>#111111</td>
                                <td>[type]0000</td>
                                <td>MM/DD/YYYY HH:MM:SS</td>
                                <td>1</td>
                            </tr>
                            <tr>
                                <td>#111111</td>
                                <td>[type]0000</td>
                                <td>MM/DD/YYYY HH:MM:SS</td>
                                <td>1</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>

        <!-- modal that pops up with further user info -->
        <div class="modal fade" id="issuesModal" tabindex="-1" aria-labelledby="issuesModal" aria-hidden="true">
            <div class="modal-dialog modal-lg  modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="issuesModalHeader">Issue Info</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="issuesModalBody">
                        <p><strong>Issue Title:</strong> [info]</p>
                        <p><strong>Reported By:</strong> [info]</p>
                        <p><strong>Flagged User:</strong> [info]</p>
                        <p><strong>Date Posted:</strong> [info]</p>
                        <p><strong>Flag Count:</strong> [info]</p>
                        <hr>
                        <p><strong>Description:</strong> [info]</p>
                        <p class="m-0"><strong>Prior Issues:</strong> [link to issue log]</p>
                    </div>
                    <div class="modal-footer">
                        <div class="d-flex gap-2">
                            <button type="button" class="btn" id="contentModalDismissBtn">Dismiss Flag</button>
                            <button type="button" class="btn" id="contentModalWarnBtn">Issue Warning</button>
                            <button type="button" class="btn" id="contentModalRemoveBtn">Remove</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
</html>
