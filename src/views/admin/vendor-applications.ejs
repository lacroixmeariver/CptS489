<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Applications</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>
<body data-role="<%= user.Role %>" data-user="<%= user.first_name %>">
    <!-- box for the main area (the entire visible screen aside from navbar basically) -->
    <div class="main-box">

        <!-- container for main dashboard content -->
        <div class="container-fluid p-5 table-container">
            <div class="d-flex align-items-center mb-2">

                <h2>Applications</h2>

                <form class="d-flex ms-auto" action="">
                    <label for="applicationSearch"></label>
                    <input type="search" class="form-control" placeholder="Search applications">
                </form>

            </div>

            <!-- tab headings for types of applications by status -->
            <ul class="nav nav-tabs" id="appTypeTabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#pendingApps">Pending</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#approvedApps">Approved</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#rejectedApps">Rejected</a>
                </li>
                <li class="nav-item"> 
                    <a href="#allApps" class="nav-link" data-bs-toggle="tab" aria-current="page">All Applications</a>
                </li>
                
            </ul>

            <!-- content/tables for each tab -->
