                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>

        <!-- modal that pops up with further user info -->
        <div class="modal fade" id="applicationModal" tabindex="-1" aria-labelledby="applicationModal" aria-hidden="true">
            <div class="modal-dialog modal-lg  modal-dialog-centered">
                <div class="modal-content" id="applicationModalContent">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="applicationInfoModal">Application Info</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="applicationModalBody">
                        <p><strong>Name:</strong> [info]</p>
                        <p><strong>Email:</strong> [info]</p>
                        <p><strong>Food Category:</strong> [info]</p>
                        <p><strong>Description:</strong> [info]</p>
                        <p><strong>Date Submitted:</strong> [info]</p>
                        <p><strong>Status:</strong> [info]</p>
                        <hr> <!-- break -->
                        <p class="m-0"><strong>Uploaded Documents: info.pdf</strong></p>
                    </div>
                    <div class="modal-footer">
                        <div class="d-flex gap-2">
                            <button type="button" class="btn" id="applicationModalApproveBtn">Approve</button>
                            <button type="button" class="btn" id="applicationModalMoreInfoBtn">Request More Info</button>
                            <button type="button" class="btn" id="applicationModalRejectBtn">Reject</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
</body>
</html>