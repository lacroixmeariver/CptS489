                                <td>jefe@eljefe.com</td>
                                <td>Vendor</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="admins">
                    <!-- ADMINS -->
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Email</th>
                                <th scope="col">Type</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody data-bs-toggle="modal" data-bs-target="#userDetailModal">
                            <tr>
                                <td>Butch T. Cougar</td>
                                <td>Butch@wsu.edu</td>
                                <td>Admin</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>John Smith</td>
                                <td>guy@email.com</td>
                                <td>Admin</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Some Dude</td>
                                <td>dude@wheresmycar.com</td>
                                <td>Admin</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>

        <!-- modal that pops up with further user info -->
        <div class="modal fade" id="userDetailModal" tabindex="-1" aria-labelledby="userDetailModal" aria-hidden="true">
            <div class="modal-dialog modal-lg  modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="userInfoModalHeader">User Info</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="userModalBody">
                        <p><strong>Name:</strong> [info]</p>
                        <p><strong>Email:</strong> [info]</p>
                        <p><strong>User Type:</strong> [info]</p>
                        <p><strong>Status:</strong> [info]</p>
                        <p><strong>Join Date:</strong> [info]</p>
                        <hr>
                        <p><strong>Order Log:</strong> [link to more]</p>
                        <p><strong>Post Log:</strong> [link to more]</p>
                        <p class="m-0"><strong>Prior Issues:</strong> [link to more]</p>
                    </div>
                    <div class="modal-footer">
                       <div class="d-flex gap-2">
                            <button type="button" class="btn" id="userModalReinstateBtn">Reinstate User</button>
                            <button type="button" class="btn" id="userModalSuspendBtn">Suspend</button>
                            <button type="button" class="btn" id="userModalBanBtn">Ban</button>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
</body>
</html>
