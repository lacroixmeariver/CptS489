                                <td><span class="status-badge status-banned">Banned</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="vendors">
                    <!-- VENDORS -->
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Email</th>
                                <th scope="col">Type</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody data-bs-toggle="modal" data-bs-target="#userDetailModal">
                            <tr>
                                <td>Ofelia's Cuban Food</td>
                                <td>oFoods@email.com</td>
                                <td>Vendor</td>
