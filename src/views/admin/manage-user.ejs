<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>
<body data-role="<%= user.role %>" data-user="<%= user.first_name %>">

    <!-- box for the main area (the entire visible screen aside from navbar basically) -->
    <div class="main-box">
        <!-- most of this content below is hard-coded dummy content (for now) -->

        <!-- container for main dashboard content -->
        <div class="container-fluid p-5 table-container">
            <div class="d-flex align-items-center mb-2">

                <h2>Manage Users</h2>

                <!-- user search form -->
                <form class="d-flex ms-auto" action="">
                    <label for="userSearch"></label>
                    <input type="search" class="form-control" placeholder="Search for a user">
                </form>

            </div>

            <!-- tab headings to quickly switch between types of users -->
            <!-- they're currently linked to these hardcoded tables but we'll have to link them to the db when we set it up -->
            <ul class="nav nav-tabs" id="userTypeTabs" role="tablist">
                <li class="nav-item"> <!-- all users is always set to initial active tab -->
                    <a href="#allUsers" class="nav-link active" data-bs-toggle="tab" aria-current="page">All Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#regUsers">Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#vendors">Vendors</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#admins">Administrators</a>
                </li>
            </ul>

            <!-- content/tables for each tab -->
            <div class="tab-content p-2">
                <div class="tab-pane fade show active" id="allUsers">
                    <table class="table">
                        <!-- ALL USERS -->
                        <thead> 
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Email</th>
                                <th scope="col">Type</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody data-bs-toggle="modal" data-bs-target="#userDetailModal">
                            <tr>
                                <td>Velma Dinkley</td>
                                <td>vDinkley@mysteryinc.com</td>
                                <td>User</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Daphne Blake</td>
                                <td>daph@mysteryinc.com</td>
                                <td>User</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Fred Jones</td>
                                <td>jones@fred.com</td>
                                <td>User</td>
                                <td><span class="status-badge status-banned">Banned</span></td>
                            </tr>
                            <tr>
                                <td>Butch T. Cougar</td>
                                <td>Butch@wsu.edu</td>
                                <td>Admin</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>John Smith</td>
                                <td>guy@email.com</td>
                                <td>Admin</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Some Dude</td>
                                <td>dude@wheresmycar.com</td>
                                <td>Admin</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Ofelia's Cuban Food</td>
                                <td>oFoods@email.com</td>
                                <td>Vendor</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Edna's AlaMode</td>
                                <td>incrediblefood@food.com</td>
                                <td>Vendor</td>
                                <td><span class="status-badge status-suspended">Suspended</span></td>
                            </tr>
                            <tr>
                                <td>Carl Casper</td>
                                <td>jefe@eljefe.com</td>
                                <td>Vendor</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="regUsers">
                    <!-- REGULAR USERS -->
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Email</th>
                                <th scope="col">Type</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody data-bs-toggle="modal" data-bs-target="#userDetailModal">
                            <tr>
                                <td>Velma Dinkley</td>
                                <td>vDinkley@mysteryinc.com</td>
                                <td>User</td>
                                <td><span class="status-badge status-active">Active</span></td>
                            </tr>
                            <tr>
                                <td>Daphne Blake</td>
