<!-- ── Hero Search ────────────────────────────── -->
<div class="browse-hero">
    <h2>What are you craving today?</h2>
    <p>Discover homemade meals from talented cooks right in your neighborhood.</p>
    <form action="search-results.html" method="get">
        <div class="browse-search-bar">
            <i class="bi bi-search" style="color:#aaa;font-size:18px;flex-shrink:0;"></i>
            <input type="text" name="q" placeholder="Search for dishes, cuisines, or cooks…">
            <button type="submit" class="search-btn">Search</button>
        </div>
    </form>
</div>

<!-- ── Category Pill Strip ───────────────────── -->
<div class="category-strip">
    <a href="search-results.html?q=all"       class="filter-pill active"><i class="bi bi-grid"></i> All</a>
    <a href="search-results.html?q=italian"   class="filter-pill">Italian</a>
    <a href="search-results.html?q=indian"    class="filter-pill">Indian</a>
