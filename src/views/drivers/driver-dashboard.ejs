<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Driver Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-dashboard.css">
    <link rel="stylesheet" href="/stylesheets/driver-dashboard.css">
</head>

<body data-role="<%= user.Role %>" data-user="<%= user.First_name %>">



    <!-- ── Dashboard Layout ───────────────────────────────── -->
    <div class="main-box">

        <!-- Main content -->
        <main class="main-content">

            <!-- Page title -->
            <div class="mb-4">
                <h1
                    style="font-family:'Poppins',sans-serif;font-size:1.6rem;font-weight:700;color:var(--charcoal-gray-secondary);margin:0;">
                    Driver Dashboard
                </h1>
                <p style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:#888;margin:4px 0 0;">
                    Manage your deliveries, track earnings, and chat with customers.
                </p>
            </div>

            <!-- Online / Offline toggle -->
            <div class="online-toggle-row">
                <div class="online-dot active" id="status-dot"></div>
                <span
                    style="font-family:'Poppins',sans-serif;font-size:0.95rem;font-weight:600;color:var(--charcoal-gray-secondary);"
                    id="status-text">
                    You are Online
                </span>
                <div class="form-check form-switch ms-auto mb-0">
                    <input class="form-check-input" type="checkbox" id="online-switch"
                        style="width:2.5em;height:1.3em;cursor:pointer;" checked onchange="toggleOnlineStatus(this)">
                </div>
            </div>

            <!-- Stat cards -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="cust-stat-card" style="border-left:4px solid var(--golden-yellow-secondary);">
                        <div class="cust-stat-icon"
                            style="background:rgba(232,180,74,.12);color:var(--golden-yellow-secondary);">
                            <i class="bi bi-bicycle"></i>
                        </div>
                        <div>
                            <div class="stat-num">
                                <%= activeDeliveries %>
                            </div>
                            <div class="stat-label">Active Delivery</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="cust-stat-card" style="border-left:4px solid var(--sage-green-secondary);">
                        <div class="cust-stat-icon"
                            style="background:rgba(122,155,110,.12);color:var(--sage-green-secondary);">
                            <i class="bi bi-check2-circle"></i>
                        </div>
                        <div>
                            <div class="stat-num">
                                <%= completedDeliveries %>
                            </div>
                            <div class="stat-label">Completed Deliveries</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="cust-stat-card" style="border-left:4px solid var(--burnt-orange-primary);">
                        <div class="cust-stat-icon"
                            style="background:rgba(197,90,58,.10);color:var(--burnt-orange-primary);">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                        <div>
                            <div class="stat-num">$312</div>
                            <div class="stat-label">Earned This Month</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="cust-stat-card" style="border-left:4px solid #5c8fd6;">
                        <div class="cust-stat-icon" style="background:rgba(92,143,214,.1);color:#5c8fd6;">
                            <i class="bi bi-star-fill"></i>
                        </div>
                        <div>
                            <div class="stat-num">4.91</div>
                            <div class="stat-label">Avg. Rating</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section tab nav -->
            <nav class="section-tab-nav mb-4">
                <a href="#" class="tab-btn active" id="tab-current-order"
                    onclick="showSection('current-order'); return false;">
                    <i class="bi bi-bicycle me-1"></i>Current Order
                </a>
                <a href="#" class="tab-btn" id="tab-history" onclick="showSection('history'); return false;">
                    <i class="bi bi-receipt me-1"></i>Order History
                </a>
                <a href="#" class="tab-btn" id="tab-earnings" onclick="showSection('earnings'); return false;">
                    <i class="bi bi-cash-stack me-1"></i>Earnings
                </a>
            </nav>

            <!-- Dynamic section content -->
            <div id="section-content">
                <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                    <div class="spinner-border" style="color:var(--golden-yellow-secondary);" role="status"></div>
                    <div class="mt-2" style="font-size:0.88rem;">Loading…</div>
                </div>
            </div>

        </main>
    </div><!-- /main-box -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sectionFiles = {
            'current-order': 'current-order',
            'history': 'history',
            'earnings': 'earnings'
        };

        function clearSection() {
            document.getElementById('section-content').innerHTML =
                '<div class="text-center py-5" style="color:#bbb;font-family:\'Poppins\',sans-serif;">' +
                '<div class="spinner-border" style="color:var(--golden-yellow-secondary);" role="status"></div>' +
                '<div class="mt-2" style="font-size:0.88rem;">Loading…</div></div>';
        }

        function setActiveTab(section) {
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            const tab = document.getElementById('tab-' + section);
            if (tab) tab.classList.add('active');
        }

        function showSection(section) {
            setActiveTab(section);
            clearSection();
            const file = sectionFiles[section];
            if (!file) return;
            fetch(file)
                .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
                .then(html => {
                    const container = document.getElementById('section-content');
                    container.innerHTML = html;
                    container.querySelectorAll('script').forEach(oldScript => {
                        const s = document.createElement('script');
                        s.textContent = oldScript.textContent;
                        oldScript.parentNode.replaceChild(s, oldScript);
                    });
                })
                .catch(err => {
                    document.getElementById('section-content').innerHTML =
                        '<div class="alert alert-danger">Could not load section: ' + err.message + '</div>';
                });
        }

        function toggleOnlineStatus(cb) {
            const dot = document.getElementById('status-dot');
            const text = document.getElementById('status-text');
            if (cb.checked) {
                dot.classList.add('active');
                text.textContent = 'You are Online';
            } else {
                dot.classList.remove('active');
                text.textContent = 'You are Offline';
            }
        }

        document.addEventListener('DOMContentLoaded', () => showSection('current-order'));
    </script>
</body>

<script src="/javascripts/common-elements.js"></script>

</html>