<!-- ================================================================
     driver-current-order.html  —  fragment for driver-dashboard.html
     Current active delivery: status updates + customer chat
     ================================================================ -->

<!-- ── Active Delivery Card ── -->
 <% if (!order && driverStatus === 'Online') { %>
  <div class="section-card text-center py-5">
    <i class="bi bi-emoji-frown-fill" style="font-size:2rem;color:#ccc;"></i>
    <p style="color:#aaa;margin-top:12px;font-family:'Poppins',sans-serif;">No active orders right now.</p>
  </div>
  
<% } else if (driverStatus === 'Offline') { %>
 <div class="section-card text-center py-5">
    <i class="bi bi-wifi-off" style="font-size:2rem;color:#ccc;"></i>
    <p style="color:#aaa;margin-top:12px;font-family:'Poppins',sans-serif;">You're offline! Get online to start delivering.</p>
  </div>
<%  } else { %>
    <span id="current-order-id" data-order-id="<%= order.OrderID %>" style="display:none;"></span>
<div class="section-card">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="section-title mb-0"><i class="bi bi-bicycle me-2"></i>Current Delivery</h2>
        <span class="badge"
            style="background:var(--golden-yellow-secondary);color:#5a3e00;font-family:'Poppins',sans-serif;font-size:0.8rem;padding:6px 12px;border-radius:20px;">
            <i class="bi bi-circle-fill me-1" style="font-size:0.55rem;"></i>In Progress
        </span>
    </div>

    <!-- Order summary -->
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <div style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.05rem;">
               <%= order.MerchantName %>
            </div>
            <div style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;margin-top:2px;">
                Order <%= order.OrderID %>
            </div>
            <div class="mt-2" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;">
                <i class="bi bi-geo-alt me-1 text-muted"></i>
                <strong>Pickup:</strong> <%= order.MerchantAddress %>
            </div>
            <div class="mt-1" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;">
                <i class="bi bi-house me-1 text-muted"></i>
                <strong>Dropoff:</strong> <%= order.DeliveryAddress %>
            </div>
        </div>
        <div class="text-end">
            <div class="stat-num" style="font-size:1.35rem;">$<%= driver.BasePay.toFixed(2) %></div>
            <div style="font-family:'Open Sans',sans-serif;font-size:0.8rem;color:#888;">Your Earnings</div>
            <div
                style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:var(--sage-green-secondary);margin-top:2px;">
                <% if (order.DriverTip > 0) { %>
                    <div ...>+$<%= order.DriverTip.toFixed(2) %> tip included</div>
                <% } %>
            </div>
        </div>
    </div>
   

    <!-- Progress tracker -->
    <div class="order-progress mb-4">
        <div class="progress-step done">
            <div class="step-icon"><i class="bi bi-check-lg"></i></div>
            <div class="step-label">Order Accepted</div>
        </div>
        <div class="progress-step done">
            <div class="step-icon"><i class="bi bi-check-lg"></i></div>
            <div class="step-label">At Restaurant</div>
        </div>
        <div class="progress-step active" id="step-picked-up">
            <div class="step-icon"><i class="bi bi-bag-check"></i></div>
            <div class="step-label">Order Picked Up</div>
        </div>
        <div class="progress-step" id="step-out-for-delivery">
            <div class="step-icon"><i class="bi bi-bicycle"></i></div>
            <div class="step-label">Out for Delivery</div>
        </div>
        <div class="progress-step" id="step-delivered">
            <div class="step-icon"><i class="bi bi-house-check"></i></div>
            <div class="step-label">Delivered</div>
        </div>
    </div>
    
    <!-- Status update buttons -->
    <div>
        <h6
            style="font-family:'Poppins',sans-serif;font-weight:600;color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px;">
            Update Order Status
        </h6>
        <div class="status-btn-grid">
            <button class="status-action-btn" id="btn-arrived"
                onclick="requestConfirm('arrived', 'Mark as Arrived at restaurant?')">
                <div class="status-icon" style="background:rgba(92,143,214,.1);color:#5c8fd6;">
                    <i class="bi bi-shop"></i>
                </div>
                <div>
                    <div>Arrived at Restaurant</div>
                    <div style="font-size:0.75rem;color:#aaa;font-weight:400;">Waiting to pick up</div>
                </div>
            </button>
            <button class="status-action-btn active-status" id="btn-picked-up"
                onclick="requestConfirm('picked-up', 'Mark order as Picked Up?')">
                <div class="status-icon" style="background:rgba(232,180,74,.15);color:#8a6000;">
                    <i class="bi bi-bag-check"></i>
                </div>
                <div>
                    <div>Order Picked Up</div>
                    <div style="font-size:0.75rem;color:#aaa;font-weight:400;">Got the order, heading out</div>
                </div>
            </button>
            <button class="status-action-btn" id="btn-out-for-delivery"
                onclick="requestConfirm('out-for-delivery', 'Mark as Out for Delivery?')">
                <div class="status-icon" style="background:rgba(197,90,58,.1);color:var(--burnt-orange-primary);">
                    <i class="bi bi-bicycle"></i>
                </div>
                <div>
                    <div>Out for Delivery</div>
                    <div style="font-size:0.75rem;color:#aaa;font-weight:400;">On the way to customer</div>
                </div>
            </button>
            <button class="status-action-btn" id="btn-delivered"
                onclick="requestConfirm('delivered', 'Confirm order as Delivered?')">
                <div class="status-icon" style="background:rgba(46,125,50,.1);color:#2e7d32;">
                    <i class="bi bi-house-check"></i>
                </div>
                <div>
                    <div>Order Delivered</div>
                    <div style="font-size:0.75rem;color:#aaa;font-weight:400;">Successfully completed</div>
                </div>
            </button>
            <!-- REPORT AN ISSUE BUTTON (commented out)
            <button class="status-action-btn" id="btn-issue" onclick="toggleIssueForm()">
                <div class="status-icon" style="background:rgba(220,53,69,.09);color:#dc3545;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div>
                    <div>Report an Issue</div>
                    <div style="font-size:0.75rem;color:#aaa;font-weight:400;">Can't complete delivery</div>
                </div>
            </button>
            -->
        </div>

        <!-- Confirm / Cancel bar (shown when a status button is clicked) -->
        <div id="confirm-bar"
            style="display:none;margin-top:14px;background:#fffbf0;border:1.5px solid rgba(232,180,74,.45);border-radius:10px;padding:12px 16px;display:none;align-items:center;gap:14px;flex-wrap:wrap;">
            <i class="bi bi-question-circle-fill"
                style="color:var(--golden-yellow-secondary);font-size:18px;flex-shrink:0;"></i>
            <span id="confirm-label"
                style="font-family:'Poppins',sans-serif;font-size:0.9rem;font-weight:600;color:var(--charcoal-gray-secondary);flex-grow:1;"></span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-hp-outline" style="border-radius:8px;"
                    onclick="cancelConfirm()">Cancel</button>
                <button class="btn btn-sm btn-hp" style="border-radius:8px;" onclick="confirmStatus()">
                    <i class="bi bi-check-lg me-1"></i>Confirm
                </button>
            </div>
        </div>

        <!-- ISSUE REPORT FORM (commented out)
        <div id="issue-form" class="mt-3" style="display:none;border:1.5px solid #f5c2c7;border-radius:10px;padding:16px 18px;background:#fff8f8;">
            <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.92rem;color:#dc3545;margin-bottom:10px;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Describe the issue
            </div>
            <textarea id="issue-text" rows="3" placeholder="e.g. Address not found, customer not responding, item damaged…"
                style="width:100%;border:1.5px solid #f5c2c7;border-radius:8px;padding:10px 12px;font-family:'Open Sans',sans-serif;font-size:0.88rem;resize:vertical;outline:none;background:#fff;"
                onfocus="this.style.borderColor='#dc3545'" onblur="this.style.borderColor='#f5c2c7'"></textarea>
            <div id="issue-text-error" style="font-family:'Open Sans',sans-serif;font-size:0.8rem;color:#dc3545;display:none;margin-top:4px;">Please describe the issue before submitting.</div>
            <div class="d-flex gap-2 mt-3 justify-content-end">
                <button class="btn btn-sm btn-hp-outline" style="border-color:#dc3545;color:#dc3545;border-radius:8px;" onclick="toggleIssueForm()">Cancel</button>
                <button class="btn btn-sm" style="background:#dc3545;color:#fff;font-family:'Poppins',sans-serif;font-weight:600;border-radius:8px;border:none;" onclick="submitIssue()">
                    <i class="bi bi-send me-1"></i>Submit Issue
                </button>
            </div>
        </div>
        -->
    </div>

    <!-- Status confirmation toast -->
    <div id="status-toast" class="mt-3 alert py-2 d-none" role="alert"
        style="font-family:'Open Sans',sans-serif;font-size:0.88rem;border-radius:8px;"></div>
</div>


<!-- ── Customer Info + Chat ── -->
<div class="section-card">
    <h2 class="section-title"><i class="bi bi-person-fill me-2"></i><%= order.CustomerFirstName %> <%= order.CustomerLastName.charAt(0) %>.</h2>

    <div class="customer-card mb-4">
        <div class="customer-avatar"><%= order.CustomerFirstName.charAt(0) %></div>
        <div class="flex-grow-1">
            <div style="font-family:'Poppins',sans-serif;font-weight:600;">Sarah K.</div>
            <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;">
                <i class="bi bi-geo-alt me-1"></i><%= order.CustomerAddress %>
            </div>
            <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;margin-top:2px;">
                <i class="bi bi-chat-left-text me-1"></i>Leave at door — thanks!
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-hp-outline"><i class="bi bi-telephone me-1"></i>Call</button>
        </div>
    </div>

    <!-- Chat -->
    <h6
        style="font-family:'Poppins',sans-serif;font-weight:600;color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">
        Messages
    </h6>
    <div class="chat-box" id="chat-box">
        <div class="chat-msg">
            <div class="chat-sender">Sarah K.</div>
            <div class="bubble">Hey! Is there any chance you can leave it at the front door? I'll be home soon 😊</div>
        </div>
        <div class="chat-msg me">
            <div class="chat-sender" style="text-align:right;">You</div>
            <div class="bubble">Sure! I'll leave it at the front door.</div>
        </div>
        <div class="chat-msg">
            <div class="chat-sender">Sarah K.</div>
            <div class="bubble">Amazing, thank you so much! 🙏</div>
        </div>
    </div>
    <div class="chat-input-row">
        <input type="text" id="chat-input" placeholder="Message the customer…"
            onkeydown="if(event.key==='Enter') sendChat()">
        <button class="btn btn-hp btn-sm" style="border-radius:20px;padding:7px 16px;" onclick="sendChat()">
            <i class="bi bi-send"></i>
        </button>
    </div>
</div>
<% }  %>
<script src="/socket.io/socket.io.js"></script>
<script>
    
    const statusConfig = {
        'arrived': { label: 'Status updated: Arrived at restaurant.', cls: 'alert-info' },
        'picked-up': { label: 'Status updated: Order picked up!', cls: 'alert-warning' },
        'out-for-delivery': { label: 'Status updated: Out for delivery!', cls: 'alert-warning' },
        'delivered': { label: '🎉 Delivery complete! Great job.', cls: 'alert-success' }
    };

    let _pendingStatus = null;

    function requestConfirm(key, message) {
        // If already confirmed this status, do nothing
        if (document.getElementById('btn-' + key).classList.contains('active-status') && _pendingStatus === null) return;
        _pendingStatus = key;
        // Dim all buttons
        document.querySelectorAll('.status-action-btn').forEach(b => {
            if (b.id !== 'btn-issue') b.style.opacity = '0.45';
        });
        document.getElementById('btn-' + key).style.opacity = '1';
        document.getElementById('btn-' + key).style.borderColor = 'var(--golden-yellow-secondary)';
        // Show confirm bar
        const bar = document.getElementById('confirm-bar');
        document.getElementById('confirm-label').textContent = message;
        bar.style.display = 'flex';
    }

    function cancelConfirm() {
        if (!_pendingStatus) return;
        document.getElementById('btn-' + _pendingStatus).style.borderColor = '';
        document.querySelectorAll('.status-action-btn').forEach(b => b.style.opacity = '');
        document.getElementById('confirm-bar').style.display = 'none';
        _pendingStatus = null;
    }

    function confirmStatus() {
        if (!_pendingStatus) return;
        const key = _pendingStatus;
        _pendingStatus = null;
        document.getElementById('confirm-bar').style.display = 'none';
        document.querySelectorAll('.status-action-btn').forEach(b => { b.style.opacity = ''; b.style.borderColor = ''; });
        updateStatus(key);
        submitStatusUpdate(key);
    }

    /* REPORT AN ISSUE JS (commented out)
    function toggleIssueForm() {
        const form = document.getElementById('issue-form');
        const btn  = document.getElementById('btn-issue');
        const isOpen = form.style.display !== 'none';
        form.style.display = isOpen ? 'none' : 'block';
        btn.classList.toggle('active-status', !isOpen);
        if (isOpen) {
            document.getElementById('issue-text').value = '';
            document.getElementById('issue-text-error').style.display = 'none';
        }
    }
    
    function submitIssue() {
        const text  = document.getElementById('issue-text').value.trim();
        const errEl = document.getElementById('issue-text-error');
        if (!text) {
            errEl.style.display = 'block';
            return;
        }
        errEl.style.display = 'none';
        document.getElementById('issue-form').style.display = 'none';
        document.getElementById('btn-issue').classList.add('active-status');
        const toast = document.getElementById('status-toast');
        toast.className = 'mt-3 alert py-2 alert-danger';
        toast.textContent = 'Issue reported: "' + escapeHtml(text) + '". Support has been notified.';
        toast.classList.remove('d-none');
        setTimeout(() => toast.classList.add('d-none'), 6000);
    }
    */

    function updateStatus(key) {
        // Highlight selected button
        document.querySelectorAll('.status-action-btn').forEach(b => b.classList.remove('active-status'));
        const btn = document.getElementById('btn-' + key);
        if (btn) btn.classList.add('active-status');

        // Advance progress steps
        const steps = ['picked-up', 'out-for-delivery', 'delivered'];
        const idx = steps.indexOf(key);
        steps.forEach((s, i) => {
            const el = document.getElementById('step-' + s);
            if (!el) return;
            el.classList.remove('done', 'active');
            if (i < idx) el.classList.add('done');
            else if (i === idx) el.classList.add('active');
        });

        // Toast
        const cfg = statusConfig[key] || { label: 'Status updated.', cls: 'alert-secondary' };
        const toast = document.getElementById('status-toast');
        toast.className = 'mt-3 alert py-2 ' + cfg.cls;
        toast.textContent = cfg.label;
        setTimeout(() => toast.classList.add('d-none'), 4000);
    }

    function sendChat() {
        const input = document.getElementById('chat-input');
        const msg = input.value.trim();
        if (!msg) return;
        const box = document.getElementById('chat-box');
        box.innerHTML +=
            '<div class="chat-msg me">' +
            '  <div class="chat-sender" style="text-align:right;">You</div>' +
            '  <div class="bubble">' + escapeHtml(msg) + '</div>' +
            '</div>';
        input.value = '';
        box.scrollTop = box.scrollHeight;
    }

    function escapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
</script>