<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .report-type-btn { min-width: 130px; }
        .report-table th { background: var(--orange-primary, #e07b3f); color: #fff; }
        .report-summary { background: var(--cream-primary, #fdf6ee); border-radius: 10px; padding: 1rem 1.5rem; }
        .report-summary .summary-val { font-size: 1.4rem; font-weight: 700; color: var(--orange-primary, #e07b3f); }
    </style>
</head>
<body data-role="<%= user.Role %>" data-user="<%= user.first_name %>">

    <div class="main-box">
        <div class="container">
            <div class="sticky-tabs-wrapper">
                <ul class="nav nav-tabs">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="daily-tab" data-bs-toggle="tab" data-bs-target="#daily-panel" type="button" role="tab">Daily</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly-panel" type="button" role="tab">Monthly</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="yearly-tab" data-bs-toggle="tab" data-bs-target="#yearly-panel" type="button" role="tab">Yearly</button>
                    </li>
                    <li class="ms-auto d-flex align-items-center pe-2">
                        <a href="/vendor/dashboard"><button class="button-cancel" type="button">Return to Dashboard</button></a>
                    </li>
                </ul>
            </div>

            <div class="tab-content" id="tabContent" style="background-color: var(--cream-primary);">
                <% [['daily','Last 30 Days'],['monthly','Last 12 Months'],['yearly','All Years']].forEach(function(pair) {
                    var period = pair[0]; var label = pair[1]; %>
                <div class="tab-pane fade <%= period === 'daily' ? 'show active' : '' %>" id="<%= period %>-panel" role="tabpanel">
                    <div class="container py-4">
                        <h4 class="mb-1" style="font-family:'Poppins',sans-serif;"><%= label %></h4>
                        <p class="text-muted mb-3" style="font-size:0.85rem;">Select a report type then click Generate.</p>

                        <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
                            <div class="btn-group" role="group">
                                <input type="radio" class="btn-check" name="type-<%= period %>" id="income-<%= period %>" value="income" autocomplete="off" checked>
                                <label class="btn btn-outline-secondary report-type-btn" for="income-<%= period %>">
                                    <i class="bi bi-currency-dollar me-1"></i>Income
                                </label>
                                <input type="radio" class="btn-check" name="type-<%= period %>" id="items-<%= period %>" value="items" autocomplete="off">
                                <label class="btn btn-outline-secondary report-type-btn" for="items-<%= period %>">
                                    <i class="bi bi-bag me-1"></i>Item Sales
                                </label>
                            </div>
                            <button class="btn btn-hp generate-btn" data-period="<%= period %>">
                                <i class="bi bi-bar-chart-line me-1"></i>Generate Report
                            </button>
                        </div>

                        <div class="alert alert-danger" id="error-<%= period %>" style="display:none;"></div>

                        <div id="results-<%= period %>" style="display:none;">
                            <div class="report-summary d-flex gap-4 flex-wrap mb-3" id="summary-<%= period %>"></div>
                            <div class="table-responsive">
                                <table class="table table-hover report-table">
                                    <thead id="thead-<%= period %>"></thead>
                                    <tbody id="tbody-<%= period %>"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/common-elements.js"></script>
    <script>
        document.querySelectorAll('.generate-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const period = this.dataset.period;
                const type = document.querySelector(`input[name="type-${period}"]:checked`).value;

                const errorEl = document.getElementById(`error-${period}`);
                const resultsEl = document.getElementById(`results-${period}`);
                const summaryEl = document.getElementById(`summary-${period}`);
                const theadEl = document.getElementById(`thead-${period}`);
                const tbodyEl = document.getElementById(`tbody-${period}`);

                errorEl.style.display = 'none';
                resultsEl.style.display = 'none';
                this.disabled = true;
                this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating…';

                try {
                    const res = await fetch(`/vendor/api/reports?period=${period}&type=${type}`);
                    const json = await res.json();

                    if (!res.ok || !json.ok) {
                        errorEl.textContent = json.error || 'Failed to generate report.';
                        errorEl.style.display = 'block';
                        return;
                    }

                    const data = json.data;
                    if (data.length === 0) {
                        errorEl.textContent = 'No completed orders found for this period.';
                        errorEl.style.display = 'block';
                        return;
                    }

                    if (type === 'income') {
                        const totalRevenue = data.reduce((s, r) => s + (r.total_revenue || 0), 0);
                        const totalOrders = data.reduce((s, r) => s + (r.order_count || 0), 0);
                        summaryEl.innerHTML = `
                            <div><div class="summary-val">$${totalRevenue.toFixed(2)}</div><div class="text-muted" style="font-size:.8rem;">Total Revenue</div></div>
                            <div><div class="summary-val">${totalOrders}</div><div class="text-muted" style="font-size:.8rem;">Orders Completed</div></div>`;
                        theadEl.innerHTML = `<tr><th>Period</th><th>Orders</th><th>Revenue</th></tr>`;
                        tbodyEl.innerHTML = data.map(r => `
                            <tr>
                                <td>${r.period_label}</td>
                                <td>${r.order_count}</td>
                                <td>$${parseFloat(r.total_revenue).toFixed(2)}</td>
                            </tr>`).join('');
                    } else {
                        const totalQty = data.reduce((s, r) => s + (r.total_qty || 0), 0);
                        const totalRevenue = data.reduce((s, r) => s + (r.total_revenue || 0), 0);
                        summaryEl.innerHTML = `
                            <div><div class="summary-val">${totalQty}</div><div class="text-muted" style="font-size:.8rem;">Items Sold</div></div>
                            <div><div class="summary-val">$${totalRevenue.toFixed(2)}</div><div class="text-muted" style="font-size:.8rem;">Total Revenue</div></div>`;
                        theadEl.innerHTML = `<tr><th>Item</th><th>Qty Sold</th><th>Revenue</th></tr>`;
                        tbodyEl.innerHTML = data.map(r => `
                            <tr>
                                <td>${r.ItemName}</td>
                                <td>${r.total_qty}</td>
                                <td>$${parseFloat(r.total_revenue).toFixed(2)}</td>
                            </tr>`).join('');
                    }

                    resultsEl.style.display = 'block';

                } catch (err) {
                    errorEl.textContent = 'An unexpected error occurred. Please try again.';
                    errorEl.style.display = 'block';
                } finally {
                    this.disabled = false;
                    this.innerHTML = '<i class="bi bi-bar-chart-line me-1"></i>Generate Report';
                }
            });
        });
    </script>
</body>
</html>